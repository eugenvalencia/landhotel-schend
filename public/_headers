# Cloudflare Pages Headers — wirkt auf dist/ nach Deploy
# Format: https://developers.cloudflare.com/pages/configuration/headers/

# Asset-Bundles (Vite-Hash im Namen) — ein Jahr immutable cachen
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fotos in /fotos/ — fester Dateiname OHNE Hash, Inhalt kann sich ändern (Foto-Tausch).
# Früher 30 Tage hart → ein ersetztes Foto blieb tagelang alt. Jetzt: kurzes Frische-Fenster
# (5 min) + stale-while-revalidate: schnell aus dem Cache, im Hintergrund auf neue Version
# geprüft, beim nächsten Aufruf von selbst ersetzt. Gute Balance ohne Pro-Bild-Overhead.
# (100 % stale-frei für immer = Hash im Dateinamen — größerer Umbau, auf Wunsch separat.)
/fotos/*
  Cache-Control: public, max-age=300, stale-while-revalidate=2592000

# Logo / Favicons / Manifest — wöchentlich neu prüfen
/icon-*
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/manifest.webmanifest
  Cache-Control: public, max-age=604800

# HTML & alles andere — IMMER gegenprüfen (max-age=0, must-revalidate).
# Cloudflare liefert das HTML ohnehin als DYNAMIC (kein Edge-Cache) → jeder Request
# bekommt den aktuellen Deploy. max-age=300 ließ aber den BROWSER die Seite 5 min
# vorhalten → Gast sah nach einem Deploy bis zu 5 min die alte Seite (alter Titel,
# alte Copy, altes Bild), F5 brachte die neue. Mit max-age=0 prüft der Browser bei
# JEDEM Aufruf nach (winziges 304 bei unverändertem HTML) → nie wieder Alt/Neu-Sprung.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'
