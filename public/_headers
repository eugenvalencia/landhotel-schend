# Cloudflare Pages Headers — wirkt auf dist/ nach Deploy
# Format: https://developers.cloudflare.com/pages/configuration/headers/

# Asset-Bundles (Vite-Hash im Namen) — ein Jahr immutable cachen
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fotos in /fotos/ — lang cachen, aber nicht immutable (kein Hash im Namen)
/fotos/*
  Cache-Control: public, max-age=2592000

# Logo / Favicons / Manifest — wöchentlich neu prüfen
/icon-*
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/manifest.webmanifest
  Cache-Control: public, max-age=604800

# HTML & alles andere — kurz cachen (Edge: 5 min, Browser: must-revalidate)
# Damit Deploys schnell sichtbar werden, ohne dass jeder Request zum Origin geht
/*
  Cache-Control: public, max-age=300, must-revalidate
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
