---
// Standort / Anreise (alle Sprachen). Google-Maps mit DSGVO-2-Klick (Karte lädt
// erst nach Zustimmung). Texte je Locale aus site/i18n/content/location.ts;
// Adresse/GPS/Höhe bleiben unverändert.
import { DEFAULT_LOCALE, type Locale } from "../i18n";
import { locationContent } from "../i18n/content/location";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const c = locationContent[lang];

const ADDRESS = "Landhaus Schend, Hauptstraße 9, 54552 Immerath, Deutschland";
const LAT = 50.1303;
const LNG = 6.9594;
const ENC = encodeURIComponent(ADDRESS);
const ROUTE_URL = `https://www.google.com/maps/dir/?api=1&destination=${ENC}`;
const MAP_SRC = `https://www.google.com/maps?q=${ENC}&output=embed&z=15`;
const APPLE_MAPS = `https://maps.apple.com/?q=${ENC}&ll=${LAT},${LNG}`;
---

<section id="location" class="bg-background">
  <div class="container mx-auto px-4 py-20 md:py-28">
    <div class="text-center mb-14 max-w-3xl mx-auto" data-reveal>
      <p class="eyebrow">{c.eyebrow}</p>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl mt-4 mb-5 text-balance leading-[1.05]">{c.h2}</h2>
      <p class="text-muted-foreground leading-relaxed">{c.subline}</p>
    </div>

    <!-- Karte (DSGVO-2-Klick) -->
    <div class="border border-border/70 rounded-md overflow-hidden shadow-card mb-10" data-reveal>
      <div data-map-placeholder class="w-full h-[360px] md:h-[480px] flex flex-col items-center justify-center gap-4 bg-muted/40 px-6 text-center">
        <svg class="h-8 w-8 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        <p class="font-display text-xl text-foreground">{c.mapTitle}</p>
        <p class="text-sm text-muted-foreground max-w-md leading-relaxed" set:html={c.mapConsentHtml} />
        <button type="button" data-map-load data-src={MAP_SRC} class="inline-flex items-center gap-2 mt-1 px-7 py-3 rounded-sm border border-primary/40 text-xs font-medium uppercase tracking-[0.18em] hover:border-secondary hover:text-secondary transition-colors">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
          {c.mapLoad}
        </button>
      </div>
    </div>

    <!-- Route-Aktionen -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-20 md:mb-24">
      <a href={ROUTE_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-7 py-3 rounded-sm border border-primary/40 text-xs font-medium uppercase tracking-[0.18em] hover:border-secondary hover:text-secondary transition-colors">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
        {c.googleMaps}
      </a>
      <a href={APPLE_MAPS} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-7 py-3 rounded-sm border border-primary/40 text-xs font-medium uppercase tracking-[0.18em] hover:border-secondary hover:text-secondary transition-colors">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
        {c.appleMaps}
      </a>
      <button type="button" data-copy-coords data-copied={c.copied} aria-label={c.copyAria} class="inline-flex items-center gap-2 px-5 py-3 text-xs uppercase tracking-[0.18em] text-muted-foreground hover:text-primary transition-colors">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span data-coords>{LAT}, {LNG}</span>
      </button>
    </div>

    <!-- Adresse · Kontakt · Entfernungen -->
    <div class="grid md:grid-cols-3 gap-px bg-border/50 mb-3 border border-border/50 rounded-md overflow-hidden shadow-card" data-reveal>
      <div class="bg-background p-8 md:p-10">
        <p class="eyebrow mb-5">{c.addrEyebrow}</p>
        <address class="not-italic text-foreground/85 leading-relaxed" set:html={c.addressHtml} />
        <div class="hairline-strong opacity-50 my-5"></div>
        <p class="text-xs text-muted-foreground leading-relaxed">
          <span class="block"><span class="text-foreground/85 font-medium">{c.hoeheLabel}</span> · {c.hoeheVal}</span>
          <span class="block"><span class="text-foreground/85 font-medium">{c.gpsLabel}</span> · {LAT}° N, {LNG}° E</span>
        </p>
      </div>
      <div class="bg-background p-8 md:p-10">
        <p class="eyebrow mb-5">{c.kontaktEyebrow}</p>
        <ul class="space-y-3 text-foreground/85">
          <li><a href="tel:+496573306" class="hover:text-secondary transition-colors">+49 6573 306</a></li>
          <li><a href="mailto:info@landhaus-schend.de" class="hover:text-secondary transition-colors break-all">info@landhaus-schend.de</a></li>
          <li><a href="https://landhaus-schend.de" class="hover:text-secondary transition-colors">www.landhaus-schend.de</a></li>
        </ul>
      </div>
      <div class="bg-background p-8 md:p-10">
        <p class="eyebrow mb-5">{c.entfernungenEyebrow}</p>
        <div class="space-y-5 text-sm">
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-secondary mb-2">{c.deutschlandLabel}</p>
            <ul class="space-y-1 text-foreground/85">
              {c.distDE.map((d) => (<li class="flex justify-between gap-3"><span class="font-medium">{d.name}</span><span class="text-muted-foreground">{d.time}</span></li>))}
            </ul>
          </div>
          <div class="hairline-strong opacity-50"></div>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-secondary mb-2">{c.beneluxLabel}</p>
            <ul class="space-y-1 text-foreground/85">
              {c.distBX.map((d) => (<li class="flex justify-between gap-3"><span class="font-medium">{d.name}</span><span class="text-muted-foreground">{d.time}</span></li>))}
            </ul>
          </div>
        </div>
        <p class="text-[11px] text-muted-foreground mt-4 leading-snug">{c.distNote}</p>
      </div>
    </div>

    <!-- Anreise: Auto · Bahn · Flugzeug -->
    <div class="grid md:grid-cols-3 gap-px bg-border/50 border border-border/50" data-reveal>
      <div class="bg-background p-8 md:p-10">
        <p class="eyebrow mb-5">{c.autoEyebrow}</p>
        <ul class="text-sm text-foreground/85 space-y-3 leading-relaxed">
          {c.autoItems.map((it) => <li set:html={it} />)}
        </ul>
      </div>
      <div class="bg-background p-8 md:p-10">
        <p class="eyebrow mb-5">{c.bahnEyebrow}</p>
        <ul class="text-sm text-foreground/85 space-y-3 leading-relaxed">
          {c.bahnItems.map((it) => <li set:html={it} />)}
        </ul>
      </div>
      <div class="bg-background p-8 md:p-10">
        <p class="eyebrow mb-5">{c.flugEyebrow}</p>
        <ul class="text-sm text-foreground/85 space-y-3 leading-relaxed">
          {c.flugItems.map((it) => <li set:html={it} />)}
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  // Karte erst nach Zustimmung laden (DSGVO).
  const btn = document.querySelector<HTMLButtonElement>("[data-map-load]");
  btn?.addEventListener("click", () => {
    const ph = document.querySelector<HTMLElement>("[data-map-placeholder]");
    const src = btn.dataset.src!;
    if (!ph) return;
    const f = document.createElement("iframe");
    f.src = src;
    f.title = "Landhaus Schend, Hauptstraße 9, 54552 Immerath – auf Google Maps";
    f.className = "w-full h-[360px] md:h-[480px] block";
    f.style.border = "0";
    f.loading = "lazy";
    f.setAttribute("allowfullscreen", "");
    f.referrerPolicy = "no-referrer-when-downgrade";
    ph.replaceWith(f);
  });

  // GPS kopieren.
  const copyBtn = document.querySelector<HTMLButtonElement>("[data-copy-coords]");
  copyBtn?.addEventListener("click", async () => {
    const label = copyBtn.querySelector("[data-coords]");
    const copied = copyBtn.dataset.copied ?? "✓";
    try {
      await navigator.clipboard.writeText("50.1303, 6.9594");
      if (label) { const prev = label.textContent; label.textContent = copied; setTimeout(() => (label.textContent = prev), 1800); }
    } catch {}
  });
</script>
