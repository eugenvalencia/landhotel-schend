---
// Öffentlicher Site-Footer (Astro, SSG). 1:1-Port aus src/components/SiteFooter.tsx.
// Immer dunkles Slate, unabhängig vom Theme — starker editorialer Seitenfuß.
import { HOTEL } from "../lib/site";

const year = new Date().getFullYear(); // build-time, landet statisch im HTML
---

<footer class="bg-[hsl(220_22%_13%)] text-[hsl(38_30%_92%)]" style="--secondary: 38 55% 60%;">
  <div class="container mx-auto px-4 py-20 md:py-24 grid gap-12 md:gap-16 md:grid-cols-12">
    <!-- Brand -->
    <div class="md:col-span-5">
      <div class="flex items-center gap-3">
        <span role="img" aria-label="Landhotel Schend Logo" class="schend-mark shrink-0 h-10 md:h-12 text-[hsl(38_30%_92%)]"></span>
        <p class="font-display text-3xl md:text-4xl leading-tight tracking-tight">Landhotel Schend</p>
      </div>
      <p class="text-[11px] tracking-[0.22em] uppercase text-[hsl(38_30%_92%)]/55 mt-3">
        Anno 1856 · Vulkaneifel
      </p>
      <p class="text-sm text-[hsl(38_30%_92%)]/75 mt-6 leading-relaxed max-w-md">
        Ihr Familienhotel in der Vulkaneifel — mit hauseigener Eifeler Landküche, ideal für Ihren Kurzurlaub.
      </p>

      <!-- Trust-Strip — Bewertungs-Aggregat als Social-Proof -->
      <div class="mt-6 inline-flex flex-wrap items-center gap-3 px-4 py-2 rounded-full border border-secondary/30 bg-secondary/5">
        <span class="star-rail relative inline-flex gap-0.5" aria-hidden="true">
          {[1, 2, 3, 4].map(() => (
            <svg class="h-3 w-3 fill-secondary text-secondary" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          ))}
          <svg class="h-3 w-3 fill-secondary/60 text-secondary" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span class="star-glint"></span>
        </span>
        <span class="text-xs text-[hsl(38_30%_92%)]/85">
          <span class="font-bold text-secondary" data-count-to="4.5" data-count-decimals="1" data-count-dur="1600">4,5</span> Ø ·
          <span class="mx-1 font-bold" data-count-to="501" data-count-dur="1600">501</span> Bewertungen
        </span>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="md:col-span-3">
      <p class="text-[11px] font-medium tracking-[0.22em] uppercase text-secondary mb-5">Quick Links</p>
      <ul class="space-y-3 text-sm">
        <li><a href="/" class="footer-link hover:text-secondary transition-colors">Startseite</a></li>
        <li><a href="/booking" class="footer-link hover:text-secondary transition-colors">Zimmer buchen</a></li>
        <li><a href="/restaurant" class="footer-link hover:text-secondary transition-colors">Gastronomie</a></li>
        <li><a href={HOTEL.phoneHref} class="footer-link hover:text-secondary transition-colors">Kontakt</a></li>
      </ul>
    </div>

    <!-- Contact -->
    <div class="md:col-span-4">
      <p class="text-[11px] font-medium tracking-[0.22em] uppercase text-secondary mb-5">Kontakt</p>
      <ul class="space-y-3 text-sm">
        <li class="flex items-center gap-3">
          <svg class="h-3.5 w-3.5 shrink-0 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
          <a href={HOTEL.phoneHref} class="footer-link hover:text-secondary transition-colors">{HOTEL.phoneLabel}</a>
        </li>
        <li class="flex items-center gap-3">
          <svg class="h-3.5 w-3.5 shrink-0 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
          <a href={`mailto:${HOTEL.email}`} class="footer-link hover:text-secondary transition-colors break-all">{HOTEL.email}</a>
        </li>
        <li class="flex items-start gap-3">
          <svg class="h-3.5 w-3.5 shrink-0 mt-0.5 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="leading-relaxed">{HOTEL.street}<br />{HOTEL.zip} {HOTEL.city}</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom strip -->
  <div class="border-t border-[hsl(38_30%_92%)]/12">
    <div class="container mx-auto px-4 py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-[hsl(38_30%_92%)]/65">
      <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-5 text-center sm:text-left">
        <p>© {year} Landhotel Schend · www.landhaus-schend.de</p>
        <span class="hidden sm:inline text-[hsl(38_30%_92%)]/25">·</span>
        <p class="text-[11px] tracking-wide text-[hsl(38_30%_92%)]/55">
          Powered by{" "}
          <a
            href="https://www.conexadigital.eu"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 align-middle hover:text-secondary underline-offset-2 hover:underline transition-colors"
          >
            <img src="/conexa-icon-white.svg" alt="" aria-hidden="true" class="conexa-diamond h-4 w-4 shrink-0" />
            CONEXA DIGITAL
          </a>
        </p>
      </div>
      <nav class="flex flex-wrap items-center justify-center md:justify-end gap-x-5" aria-label="Rechtliches">
        <a href="/impressum" class="footer-link inline-flex items-center min-h-11 py-1.5 hover:text-secondary transition-colors">Impressum</a>
        <a href="/datenschutz" class="footer-link inline-flex items-center min-h-11 py-1.5 hover:text-secondary transition-colors">Datenschutz</a>
        <a href="/agb" class="footer-link inline-flex items-center min-h-11 py-1.5 hover:text-secondary transition-colors">AGB</a>
        <a href="/barrierefreiheit" class="footer-link inline-flex items-center min-h-11 py-1.5 hover:text-secondary transition-colors">Barrierefreiheit</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  /* Stern-Glint — derselbe wandernde Gold-Funke wie in der Timeline, läuft
     fortlaufend über die 5 Sterne und lässt sie beim Vorbeiziehen aufleuchten. */
  .star-rail { overflow: visible; }
  .star-glint {
    position: absolute;
    top: 50%;
    left: 0;
    width: 20px;
    height: 14px;
    transform: translateY(-50%);
    border-radius: 9999px;
    background: radial-gradient(closest-side, rgba(255, 244, 214, 0.95), rgba(255, 244, 214, 0) 70%);
    filter: blur(1px);
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    animation: star-glint-sweep 3.4s ease-in-out 1s infinite;
  }
  @keyframes star-glint-sweep {
    0%   { left: 0;    opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .star-glint { animation: none; opacity: 0; }
  }
</style>
