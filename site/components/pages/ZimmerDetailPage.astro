---
// Geteilte „Zimmer-Detail"-Seite (alle Sprachen). Inhalt lokalisiert aus
// site/i18n/content/zimmer.ts. DE-Schema nutzt das Original roomSchema() (byte-gleich).
import Layout from "../../layouts/Layout.astro";
import Pic from "../Pic.astro";
import { ORIGIN } from "../../lib/site";
import { roomSchema, findRoom } from "../../lib/rooms";
import { DEFAULT_LOCALE, localizedPath, type Locale } from "../../i18n";
import { findRoomFor, zimmerChrome } from "../../i18n/content/zimmer";

interface Props {
  lang?: Locale;
  slug: string;
}
const { lang = DEFAULT_LOCALE, slug } = Astro.props;
const c = zimmerChrome[lang];
const room = findRoomFor(slug, lang)!;

// DE: exakt das Original-Schema; sonst lokalisiert (gleiche Struktur).
const schema =
  lang === DEFAULT_LOCALE
    ? roomSchema(findRoom(slug)!)
    : {
        "@context": "https://schema.org",
        "@type": "HotelRoom",
        name: `${room.type} — Landhaus Schend`,
        description: room.description,
        url: `${ORIGIN}${localizedPath(`/zimmer/${room.slug}`, lang)}`,
        image: room.gallery.map((g) => `${ORIGIN}${g}`),
        occupancy: { "@type": "QuantitativeValue", maxValue: room.maxPersons, unitText: c.schemaPersonsUnit },
        bed: { "@type": "BedDetails", typeOfBed: room.bed },
        amenityFeature: room.amenities.map((a) => ({ "@type": "LocationFeatureSpecification", name: a, value: true })),
        isPartOf: { "@id": "https://landhaus-schend.de/#hotel" },
        makesOffer: {
          "@type": "Offer",
          price: room.priceFrom,
          priceCurrency: "EUR",
          description: `${room.priceLabel}, ${c.schemaOfferBreakfast}`,
          availability: "https://schema.org/InStock",
        },
      };

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: c.breadcrumbHome, item: `${ORIGIN}${localizedPath("/", lang)}` },
    { "@type": "ListItem", position: 2, name: c.breadcrumbList, item: `${ORIGIN}${localizedPath("/zimmer", lang)}` },
    { "@type": "ListItem", position: 3, name: room.type, item: `${ORIGIN}${localizedPath(`/zimmer/${room.slug}`, lang)}` },
  ],
};
---

<Layout
  title={`${room.type} — ${c.detailTitleSuffix}`}
  description={room.description}
  canonicalPath={localizedPath(`/zimmer/${room.slug}`, lang)}
  ogImage={room.gallery[0]}
  lang={lang}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />

  <!-- Hero -->
  <section class="relative">
    <Pic src={room.gallery[0]} alt={`${room.type} ${c.altSuffix}`} class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    <div class="absolute inset-0 gradient-hero"></div>
    <div class="relative container mx-auto px-4 py-24 md:py-32 max-w-3xl text-[hsl(38_30%_95%)]" style="text-shadow:0 2px 16px rgba(0,0,0,0.7),0 1px 3px rgba(0,0,0,0.55)">
      <a href={localizedPath("/zimmer", lang)} class="inline-flex items-center gap-1.5 text-sm text-[hsl(38_30%_95%)]/80 hover:text-[hsl(38_30%_95%)] transition-colors mb-5">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        {c.backToAll}
      </a>
      <p class="eyebrow !text-[hsl(38_48%_72%)]">{c.detailEyebrow}</p>
      <h1 class="font-display text-4xl md:text-6xl mt-3 text-balance leading-[1.05]">{room.type}</h1>
      <p class="font-display text-2xl md:text-3xl text-[hsl(38_48%_78%)] mt-5">{room.priceLabel} <span class="text-base font-sans text-[hsl(38_30%_95%)]/80">{c.inklFruehstueck}</span></p>
      {room.priceNote && <p class="text-sm text-[hsl(38_30%_95%)]/80 mt-1">{room.priceNote}</p>}
    </div>
  </section>

  <section class="container mx-auto px-4 py-16 md:py-20 max-w-3xl">
    <!-- Eckdaten -->
    <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm mb-8">
      <span class="inline-flex items-center gap-2"><span class="text-muted-foreground">{c.occupancyLabel}</span> <span class="font-medium">{c.occupancyUpTo} {room.maxPersons} {room.maxPersons === 1 ? c.personSg : c.personPl}</span></span>
      <span class="inline-flex items-center gap-2"><span class="text-muted-foreground">{c.bedLabel}</span> <span class="font-medium">{room.bed}</span></span>
    </div>

    <p class="text-xl leading-relaxed text-foreground/90 text-pretty">{room.description}</p>

    <div class="hairline my-10"></div>

    <h2 class="font-display text-2xl md:text-3xl mb-6">{c.ausstattungDetailH2}</h2>
    <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
      {room.amenities.map((a) => (
        <li class="flex items-start gap-3">
          <svg class="h-5 w-5 shrink-0 mt-0.5 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="text-foreground/90">{a}</span>
        </li>
      ))}
    </ul>

    {room.gallery.length > 1 && (
      <>
        <div class="hairline my-10"></div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {room.gallery.map((src, i) => (
            <div class="aspect-[4/3] overflow-hidden rounded-md" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
              <Pic src={src} alt={`${room.type} — ${c.ansichtLabel} ${i + 1}`} data-lightbox="zimmer" class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
          ))}
        </div>
      </>
    )}

    <p class="text-xs text-muted-foreground mt-8">{c.beispielHinweisDetail}</p>

    <div class="mt-12 flex flex-wrap gap-3">
      <a href={localizedPath("/anfrage", lang)} class="inline-flex items-center px-6 py-3 rounded-sm bg-secondary text-secondary-foreground font-semibold tracking-wide hover:bg-secondary/90 transition-colors">
        {c.unverbindlichAnfragen}
      </a>
      <a href="tel:+496573306" class="inline-flex items-center px-6 py-3 rounded-sm border border-border font-semibold tracking-wide hover:bg-muted transition-colors">
        +49 6573 306
      </a>
    </div>
    <p class="text-sm text-muted-foreground mt-4">{c.commissionNote}</p>
  </section>
</Layout>
