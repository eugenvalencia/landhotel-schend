  <style>
    #section-dots[data-visible="true"] { opacity: 1; pointer-events: auto; }
    #section-dots .dot-link[data-active="true"] .dot {
      width: 0.75rem; height: 0.75rem;
      background: hsl(var(--secondary));
      box-shadow: 0 0 8px hsl(var(--secondary) / 0.4);
    }
  </style>
  <script>
    (function () {
      const nav = document.getElementById("section-dots");
      if (!nav) return;
      const ids = ["top", "rooms", "restaurant", "pakete", "reviews", "location"];
      const links = Array.from(nav.querySelectorAll<HTMLElement>("[data-dot]"));
      const update = (y: number) => {
        const anchorY = y + window.innerHeight * 0.4;
        let bestId = "top";
        let bestStart = -Infinity;
        for (const id of ids) {
          const el = document.getElementById(id);
          if (!el) continue;
          const rect = el.getBoundingClientRect();
          const start = rect.top + y;
          if (anchorY >= start && anchorY < start + rect.height && start > bestStart) {
            bestStart = start;
            bestId = id;
          }
        }
        links.forEach((a) =>
          a.setAttribute("data-active", a.getAttribute("data-dot") === bestId ? "true" : "false"),
        );
        const visible = y > window.innerHeight * 0.6;
        nav.setAttribute("data-visible", visible ? "true" : "false");
        (nav as HTMLElement & { inert: boolean }).inert = !visible;
      };
      if ((window as any).__onScroll) (window as any).__onScroll(update);
      else {
        update(window.scrollY);
        window.addEventListener("scroll", () => update(window.scrollY), { passive: true });
      }
      window.addEventListener("resize", () => update((window as any).__lenis?.scroll ?? window.scrollY));
    })();
  </script>

  <script>
    const heroVideo = document.querySelector<HTMLVideoElement>("[data-hero-video]");
    const motionOff = window.matchMedia("(prefers-reduced-motion: reduce)").matches
      || document.documentElement.classList.contains("a11y-reduced-motion");
    const noHeroVideo = motionOff || !window.matchMedia("(min-width: 768px)").matches;
    if (heroVideo && noHeroVideo) {
      heroVideo.pause();
    } else if (heroVideo) {
      let inView = true;
      const tryPlay = () => {
        if (inView && !document.hidden && heroVideo.paused) heroVideo.play().catch(() => {});
      };
      tryPlay();
      heroVideo.addEventListener("loadedmetadata", tryPlay, { once: true });
      heroVideo.addEventListener("loadeddata", tryPlay, { once: true });
      heroVideo.addEventListener("canplay", tryPlay, { once: true });
      if ("IntersectionObserver" in window) {
        new IntersectionObserver((entries) => {
          inView = entries[0].isIntersecting;
          if (inView) tryPlay();
          else heroVideo.pause();
        }, { threshold: 0.1 }).observe(heroVideo);
      }
      document.addEventListener("visibilitychange", () => { if (!document.hidden) tryPlay(); });
      heroVideo.addEventListener("pause", () => {
        if (inView && !document.hidden && !heroVideo.ended) setTimeout(tryPlay, 150);
      });
    }

    const bg = document.querySelector<HTMLElement>("[data-hero-bg]");
    if (bg && !motionOff) {
      let raf = 0;
      const applyParallax = (sy: number) => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const h = bg.offsetHeight || 1;
          const y = Math.min(sy * 0.3, h * 0.06);
          bg.style.transform = `translate3d(0, ${y}px, 0) scale(1.22)`;
        });
      };
      if ((window as any).__onScroll) {
        (window as any).__onScroll(applyParallax);
      } else {
        applyParallax(window.scrollY);
        window.addEventListener("scroll", () => applyParallax(window.scrollY), { passive: true });
      }
    }
  </script>
