---
// Geteilte Startseite (alle Sprachen). Markup + Effekte EINMAL; Inhalt je Locale
// aus site/i18n/content/home.ts, Zimmer-/Paket-Karten aus den lokalisierten
// Datenschichten. DE rendert inhaltsgleich zur bisherigen index.astro.
import Layout from "../../layouts/Layout.astro";
import Pic from "../Pic.astro";
import LocationSection from "../LocationSection.astro";
import { ROOM_TYPES } from "../../lib/rooms";
import { SCHEND_RESTAURANT, galleryForRoomType } from "../../lib/photos";
import { GUEST_VOICES } from "../../lib/guest-voices";
import { fromOffer } from "../../lib/schema";
import { DEFAULT_LOCALE, localizedPath, type Locale } from "../../i18n";
import { t } from "../../i18n/ui";
import { homeContent } from "../../i18n/content/home";
import { findRoomFor, zimmerChrome } from "../../i18n/content/zimmer";
import { paketeFor } from "../../i18n/content/pakete";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const c = homeContent[lang];
const pakete = paketeFor(lang);
const altSuffix = zimmerChrome[lang].altSuffix;

const HERO_VIDEO = "/hero/schend-hero.mp4";
const HERO_POSTER = "/hero/schend-hero-poster.webp";

const FOOD_PHOTOS = [
  "/marquee/food-0.jpg",
  "/marquee/haehnchen-mit-wedges-landhaus-schend.jpg",
  "/marquee/food-1.jpg",
  "/marquee/schnitzelteller-mit-pommes-landhaus-schend.jpg",
  "/marquee/food-2.jpg",
  "/marquee/rouladen-mit-rotkohl-und-kroketten-landhaus-schend.jpg",
  "/marquee/food-3.jpg",
  "/marquee/schlemmerplatte-landhaus-schend.jpg",
  "/marquee/salat-buffet-mit-tomatenherz-landhaus-schend.jpg",
  "/marquee/warmes-buffet-mit-chafing-dishes-landhaus-schend.jpg",
  "/marquee/schnitzel-mit-salat-landhaus-schend.jpg",
  "/marquee/cordon-bleu-mit-pommes-landhaus-schend.jpg",
];

const REGION_SRC = ["/region/eifel-1.jpg", "/region/eifel-2.jpg", "/region/eifel-3.jpg", "/region/eifel-4.jpg", "/region/eifel-5.jpg"];
const REGION_CLS = ["md:row-span-2 md:h-[33rem]", "md:col-span-2", "md:row-span-2 md:h-[33rem]", "", ""];

const PLATFORMS = [
  { name: "Booking.com", logo: "/reviews/booking.svg", score: "8,8 / 10", href: "https://www.booking.com/hotel/de/landhaus-schend.html" },
  { name: "Tripadvisor", logo: "/reviews/tripadvisor.svg", score: "4,0 / 5", href: "https://www.tripadvisor.com/Hotel_Review-g2298352-d2330477-Reviews-Landhaus_Schend-Immerath_Rhineland_Palatinate.html" },
  { name: "HRS", mark: "HRS", brand: "#1d4ed8", score: "9,0 / 10", href: "https://www.hrs.com/en/hotel/schend-landhaus/a-542374/" },
  { name: "Google", logo: "/reviews/google.svg", score: "", href: "https://www.google.com/maps/search/?api=1&query=Landhaus+Schend+Immerath" },
];

const hotelGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Hotel",
      "@id": "https://landhaus-schend.de/#hotel",
      name: "Landhaus Schend",
      alternateName: "Landhaus Schend Hotel - Restaurant",
      legalName: "Landhaus Schend, Hotel - Restaurant",
      description: c.schemaHotelDescription,
      url: "https://landhaus-schend.de/",
      telephone: "+49-6573-306",
      faxNumber: "+49-6573-99815",
      email: "info@landhaus-schend.de",
      image: [
        "https://landhaus-schend.de/fotos/hotelfront-mit-rosen-landhaus-schend-vulkaneifel.jpg",
        "https://landhaus-schend.de/fotos/gartenseite-mit-terrasse-landhaus-schend.jpg",
      ],
      logo: "https://landhaus-schend.de/schend-logo-black.svg",
      priceRange: "€€",
      // Günstigster realer Einstieg: Doppelzimmer ab 57 €/Person inkl. Frühstück.
      makesOffer: fromOffer(57, { url: "https://landhaus-schend.de/anfrage/", description: "ab 57 € pro Person/Nacht inkl. Frühstück" }),
      starRating: { "@type": "Rating", ratingValue: "3", bestRating: "5", worstRating: "1" },
      address: { "@type": "PostalAddress", streetAddress: "Hauptstraße 9", addressLocality: "Immerath", addressRegion: "Rheinland-Pfalz", postalCode: "54552", addressCountry: "DE" },
      geo: { "@type": "GeoCoordinates", latitude: 50.1303, longitude: 6.9594 },
      hasMap: "https://www.google.com/maps?q=Landhaus+Schend+Immerath",
      checkinTime: "15:00",
      checkoutTime: "11:00",
      numberOfRooms: 21,
      smokingAllowed: false,
      amenityFeature: [
        { "@type": "LocationFeatureSpecification", name: "Halbpension auf Wunsch", value: true },
        { "@type": "LocationFeatureSpecification", name: "Eifeler Landküche", value: true },
        { "@type": "LocationFeatureSpecification", name: "Hauseigenes Restaurant", value: true },
        { "@type": "LocationFeatureSpecification", name: "Frühstücksbuffet", value: true },
        { "@type": "LocationFeatureSpecification", name: "Kostenloses WLAN", value: true },
        { "@type": "LocationFeatureSpecification", name: "Kostenloser Parkplatz", value: true },
        { "@type": "LocationFeatureSpecification", name: "Motorrad-Stellplätze", value: true },
        { "@type": "LocationFeatureSpecification", name: "Balkon oder Terrasse", value: true },
        { "@type": "LocationFeatureSpecification", name: "Massagen", value: true },
        { "@type": "LocationFeatureSpecification", name: "Familienzimmer", value: true },
      ],
      potentialAction: { "@type": "ReserveAction", target: { "@type": "EntryPoint", urlTemplate: "https://landhaus-schend.de/anfrage/", actionPlatform: ["https://schema.org/DesktopWebPlatform", "https://schema.org/MobileWebPlatform"] }, result: { "@type": "LodgingReservation", name: "Direktbuchung Zimmer" } },
      // Rück-Referenz aufs hauseigene Restaurant (schließt die Verknüpfung zum
      // einseitigen containedInPlace auf der Restaurant-Seite).
      containsPlace: { "@id": "https://landhaus-schend.de/restaurant/#restaurant" },
      // Aggregierte Gäste-Bewertung — Booking.com als Quelle (größte, transparente
      // Stichprobe: 8,8/10 aus 277 Bewertungen, 1:1 zum sichtbaren Footer/Reviews-
      // Abschnitt; kein erfundener Mittelwert über verschiedene Skalen). Wert v.a. für
      // GEO/KI-Suche (LLM-Zitate) — Google zeigt für Hotels self-serving Sterne oft
      // NICHT. UWG/Marken-Prüfung der Plattform-Nennung durch Walter vor Go-Live.
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "8.8",
        bestRating: "10",
        worstRating: "1",
        ratingCount: "277",
      },
    },
    {
      "@type": "Organization", "@id": "https://landhaus-schend.de/#organization",
      name: "Landhaus Schend", alternateName: "Landhaus Schend", url: "https://landhaus-schend.de/",
      logo: "https://landhaus-schend.de/schend-logo-black.svg",
      foundingDate: "1856",
      contactPoint: { "@type": "ContactPoint", telephone: "+49-6573-306", contactType: "Reservierung", areaServed: "DE", availableLanguage: ["German"] },
      sameAs: ["https://www.facebook.com/Landhotel.Schend/", "https://www.instagram.com/landhaus_schend/", "https://www.booking.com/hotel/de/landhaus-schend.html", "https://www.tripadvisor.com/Hotel_Review-g2298352-d2330477-Reviews-Landhaus_Schend-Immerath_Rhineland_Palatinate.html"],
    },
    { "@type": "WebSite", "@id": "https://landhaus-schend.de/#website", url: "https://landhaus-schend.de/", name: "Landhaus Schend", publisher: { "@id": "https://landhaus-schend.de/#organization" }, inLanguage: [c.schemaInLanguage] },
  ],
};

// FAQPage-Schema aus dem Home-FAQ-Auszug (1:1 zu c.faqHome, je Sprache) — gleiches
// Muster wie FaqPage.astro, damit die 6 sichtbaren Fragen Rich-Result-fähig sind.
const faqGraph = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: c.faqHome.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const uspIcon: Record<string, string> = {
  park: '<circle cx="12" cy="12" r="10"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>',
  bike: '<circle cx="5.5" cy="17.5" r="3.5"/><circle cx="18.5" cy="17.5" r="3.5"/><path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/>',
  chef: '<path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/>',
  utensils: '<path d="M3 2v7c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>',
  bed: '<path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/>',
  wifi: '<path d="M5 13a10 10 0 0 1 14 0"/><path d="M8.5 16.5a5 5 0 0 1 7 0"/><path d="M2 8.82a15 15 0 0 1 20 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
  coffee: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/>',
  trophy: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
};

const USP_ICONS = ["park", "bike", "chef", "utensils", "bed", "wifi", "coffee", "trophy"];
const stripPrefix = (s: string) => s.replace(/^(ab|from|vanaf)\s+/i, "").replace(/^à partir de\s+/i, "");
const dotIds = ["top", "rooms", "restaurant", "pakete", "reviews", "location"];
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  canonicalPath={localizedPath("/", lang)}
  lang={lang}
  ogType="hotel"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(hotelGraph)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqGraph)} />
  <link rel="preload" as="image" href={HERO_POSTER} type="image/webp" fetchpriority="high" slot="head" />

  <!-- HERO -->
  <section id="top" class="relative h-[100vh] min-h-[640px] max-h-[1100px] overflow-hidden">
    <div data-hero-bg aria-hidden="true" class="absolute inset-0 will-change-transform" style="transform: scale(1.22)">
      <video data-hero-video class="absolute inset-0 w-full h-full object-cover" poster={HERO_POSTER} muted loop playsinline preload="none" aria-hidden="true">
        <source src={HERO_VIDEO} type="video/mp4" />
      </video>
    </div>
    <div aria-hidden="true" class="absolute inset-0 bg-black/15"></div>
    <div aria-hidden="true" class="absolute inset-0" style="background: radial-gradient(ellipse 65% 55% at 50% 50%, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.12) 55%, transparent 100%)"></div>
    <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-80 bg-gradient-to-t from-black/55 via-black/20 to-transparent"></div>
    <div aria-hidden="true" class="hero-grain absolute inset-0 z-[1] pointer-events-none"></div>

    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6">
      <div class="flex items-center gap-4 mb-10 md:mb-14">
        <span class="block h-px w-12 md:w-20 bg-white/65"></span>
        <span class="text-[11px] md:text-xs font-medium tracking-[0.24em] uppercase text-white/90" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">{c.heroBadge}</span>
        <span class="block h-px w-12 md:w-20 bg-white/65"></span>
      </div>
      <h1 class="headline-reveal font-display text-balance text-white text-[2.5rem] sm:text-5xl md:text-7xl lg:text-[5.5rem] leading-[0.95] mb-7 md:mb-9 max-w-4xl" style="text-shadow:0 2px 14px rgba(0,0,0,0.55)">
        {c.heroH1}
      </h1>
      <p class="font-display-italic text-balance text-white/95 text-base sm:text-lg md:text-2xl max-w-2xl leading-snug mb-8 sm:mb-9 md:mb-11" style="text-shadow:0 1px 8px rgba(0,0,0,0.55)">
        {c.heroSubtitle}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 mb-10 md:mb-12 text-white/80" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">
        <span class="text-xs tracking-[0.12em] uppercase font-medium"><span class="text-secondary">★</span> {c.statTripadvisor}</span>
        <span class="text-white/40" aria-hidden="true">·</span>
        <span class="text-xs tracking-[0.12em] uppercase font-medium"><span data-count-to="8.8" data-count-decimals="1" data-count-mount="1" data-count-delay="600" data-count-dur="1400">8,8</span> {c.statBooking}</span>
        <span class="text-white/40" aria-hidden="true">·</span>
        <span class="text-xs tracking-[0.12em] uppercase font-medium"><span data-count-to="170" data-count-mount="1" data-count-delay="800" data-count-dur="1600">170</span> {c.statTradition}</span>
        <span class="text-white/40 hidden sm:inline" aria-hidden="true">·</span>
        <span class="hidden sm:inline text-xs tracking-[0.12em] uppercase font-medium"><span data-count-to="21" data-count-mount="1" data-count-delay="1000" data-count-dur="1200">21</span> {c.statRooms}</span>
      </div>
      <div class="flex flex-col items-center gap-5">
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4">
          <a href={localizedPath("/anfrage", lang)} class="magnetic glow-border group inline-flex items-center justify-center gap-3 px-9 py-4 min-h-[56px] bg-white text-zinc-900 text-xs sm:text-sm font-medium tracking-[0.2em] uppercase rounded-sm hover:bg-secondary hover:text-secondary-foreground transition-colors duration-300 shadow-sm">
            <svg class="h-4 w-4 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/><path d="m9 16 2 2 4-4"/></svg>
            {c.ctaInquire}
            <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </a>
          <a href={localizedPath("/restaurant", lang)} class="magnetic group inline-flex items-center justify-center gap-3 px-9 py-4 min-h-[56px] border border-white/60 text-white text-xs sm:text-sm font-medium tracking-[0.2em] uppercase rounded-sm hover:bg-white/10 hover:border-white transition-all duration-300" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">
            <svg class="h-4 w-4 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            {c.ctaRestaurant}
            <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </a>
        </div>
        <a href="tel:+496573306" class="text-white/85 text-sm tracking-wide hover:text-white transition-colors" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">{c.callPrefix} <span class="font-medium ml-1">+49 6573 306</span></a>
      </div>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 text-white/55">
      <span class="text-[10px] tracking-[0.3em] uppercase">{c.scrollLabel}</span>
      <span class="relative block h-10 w-px overflow-hidden bg-white/20"><span aria-hidden="true" class="scroll-cue-travel absolute inset-x-0 top-0 block h-3 bg-white/85"></span></span>
    </div>
  </section>

  <!-- USPs -->
  <section aria-label={c.uspsAria} class="bg-background border-y border-border/70">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-border/50">
        {c.usps.map((label, i) => (
          <div class="group flex items-center gap-3 px-5 py-7 bg-background hover:bg-muted/40 transition-colors">
            <svg class="h-5 w-5 text-secondary shrink-0 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={uspIcon[USP_ICONS[i]]} />
            <span class="text-[13px] font-medium leading-snug">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ZIMMER -->
  <section id="rooms" class="bg-gradient-to-b from-background via-muted/20 to-background">
    <div class="container mx-auto px-4 py-20 md:py-28">
      <div class="text-center mb-14 md:mb-20" data-reveal>
        <span class="hairline block max-w-[3rem] mx-auto mb-6"></span>        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl text-balance">{c.roomsH2}</h2>
        <p class="text-muted-foreground mt-5 max-w-prose mx-auto leading-relaxed text-pretty">
          {c.roomsIntro}
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-10 max-w-4xl mx-auto">
        {ROOM_TYPES.map((base, idx) => {
          const gallery = galleryForRoomType(base.type);
          const cardPhoto = gallery[idx % gallery.length] ?? gallery[0];
          const r = findRoomFor(base.slug, lang)!;
          return (
            <a href={localizedPath(`/zimmer/${base.slug}`, lang)} class="group block" data-reveal style={`--reveal-delay:${idx * 0.08}s`}>
              <div class="spotlight tilt-card card-reveal aspect-[3/4] sm:aspect-[4/5] overflow-hidden mb-5 rounded-md shadow-card group-hover:shadow-elevated transition-shadow duration-500">
                <Pic src={cardPhoto} alt={`${r.type} ${altSuffix}, Vulkaneifel`} class="w-full h-full object-cover transition-transform duration-[1500ms] ease-out group-hover:scale-[1.04]" loading="lazy" decoding="async" sizes="(min-width: 640px) 440px, 92vw" />
                <div class="card-caption">
                  <p class="text-[10px] tracking-[0.2em] uppercase text-white/80 mb-1">{c.roomCardEyebrow}</p>
                  <p class="font-display text-white text-lg leading-snug">{r.hint}</p>
                </div>
              </div>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4 mb-2">
                <h3 class="font-display text-xl md:text-2xl group-hover:text-secondary transition-colors">{r.type}</h3>
                <span class="text-xs font-medium tracking-[0.15em] uppercase text-secondary whitespace-nowrap">{r.priceLabel}</span>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed">{r.hint}</p>
            </a>
          );
        })}
      </div>
      <div class="text-center mt-16">
        <a href={localizedPath("/zimmer", lang)} class="inline-flex items-center gap-2 px-9 py-4 rounded-sm border border-primary/40 uppercase tracking-[0.2em] text-xs font-medium hover:border-secondary hover:text-secondary transition-colors">{c.allRoomsCta} <span>→</span></a>
      </div>
    </div>
  </section>

  <!-- ANFRAGE-CTA (dezenter Inline-Streifen zwischen Zimmer & Pakete) -->
  <section aria-labelledby="cta-strip-title" class="bg-muted/30 border-y border-border/60">
    <div class="container mx-auto px-4 py-12 md:py-14">
      <div class="max-w-3xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-6 text-center md:text-left" data-reveal>
        <div>
          <span class="hairline block max-w-[3rem] mx-auto md:mx-0 mb-4"></span>
          <h2 id="cta-strip-title" class="font-display text-2xl md:text-3xl text-balance leading-snug">{c.ctaStripTitle}</h2>
          <p class="text-sm text-muted-foreground mt-3 leading-relaxed text-pretty max-w-prose mx-auto md:mx-0">{c.ctaStripText}</p>
        </div>
        <a href={localizedPath("/anfrage", lang)} class="shrink-0 inline-flex items-center justify-center gap-3 px-8 py-4 min-h-[52px] bg-primary text-primary-foreground rounded-sm text-xs sm:text-sm font-medium tracking-[0.2em] uppercase hover:bg-secondary hover:text-secondary-foreground transition-colors">
          {c.ctaStripButton}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- RESTAURANT (voll) -->
  <section id="restaurant" class="bg-gradient-to-b from-muted/40 via-muted/20 to-muted/40">
    <div class="animate-pulse-banner border-y border-border/60">
      <div class="container mx-auto px-4 py-4 md:py-5">
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-center">
          <span class="inline-flex items-center gap-2 text-sm md:text-base font-medium text-foreground">
            <svg class="h-4 w-4 text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            {c.banner}
          </span>
          <a href="tel:+496573306" class="inline-flex items-center gap-2 text-sm font-medium text-secondary hover:text-foreground transition-colors underline underline-offset-4 decoration-secondary/40">{c.bannerReserve}</a>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-12 items-stretch">
      <div class="lg:col-span-7 lg:order-last">
        <div class="aspect-[4/3] lg:aspect-auto lg:h-full lg:min-h-[640px] overflow-hidden shadow-card">
