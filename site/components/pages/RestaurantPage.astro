---
// Geteilte „Restaurant"-Seite (alle Sprachen). Markup + Animationen EINMAL;
// Inhalt je Locale aus site/i18n/content/restaurant.ts. Restaurant-Schema je Sprache.
import Layout from "../../layouts/Layout.astro";
import Pic from "../Pic.astro";
import { ORIGIN } from "../../lib/site";
import { breadcrumbLd, homeCrumb } from "../../lib/schema";
import { SCHEND_RESTAURANT } from "../../lib/photos";
import { DEFAULT_LOCALE, localizedPath, type Locale } from "../../i18n";
import { restaurantContent } from "../../i18n/content/restaurant";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const c = restaurantContent[lang];

// Küchen-Tags je Sprache (einzige sprachabhängige Schema-Eigenschaft).
const CUISINE: Record<Locale, string[]> = {
  de: ["Eifeler Landküche", "Deutsch", "Regional"],
  en: ["Eifel country cuisine", "German", "Regional"],
  fr: ["Cuisine de l'Eifel", "Allemande", "Régionale"],
  nl: ["Eifeler streekkeuken", "Duits", "Regionaal"],
};
// @id je Sprache eindeutig; DE bleibt byte-gleich zur Home-containsPlace-Referenz.
const restId = lang === "de"
  ? "https://landhaus-schend.de/restaurant#restaurant"
  : `${ORIGIN}${localizedPath("/restaurant", lang)}#restaurant`;
const breadcrumb = breadcrumbLd(ORIGIN, lang, [homeCrumb(lang), { name: "Restaurant", path: "/restaurant" }]);

// Laufband — NUR Essen (keine Saal-/Panorama-Aufnahmen, Beimler-Wunsch 20.06.).
const FOOD_PHOTOS = [
  "/pakete/food-0.jpg",
  "/fotos/suesse-nachspeise-mit-schokoladensauce-landhaus-schend.jpg",
  "/pakete/food-1.jpg",
  "/fotos/pelmeni-beimler-landhaus-schend.jpg",
  "/pakete/food-2.jpg",
  "/fotos/ueberbackenes-gericht-mit-kroketten-landhaus-schend.jpg",
  "/pakete/food-3.jpg",
  "/fotos/forelle-mit-petersilienkartoffeln-landhaus-schend.jpg",
  "/fotos/eifeler-spezialitaet-gebratene-kloesse-in-rahmsauce-landhaus-schend.jpg",
  "/fotos/grillteller-tablett-am-fenstertisch-landhaus-schend.jpg",
  "/fotos/kaese-schnitzel-mit-preiselbeeren-und-bratkartoffeln-landhaus-schend.jpg",
];

const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "@id": restId,
  name: "Landhaus Restaurant & Terrasse",
  alternateName: "Restaurant Landhaus Schend",
  url: `${ORIGIN}${localizedPath("/restaurant", lang)}`,
  description: c.schemaDescription,
  telephone: "+49-6573-306",
  email: "info@landhaus-schend.de",
  servesCuisine: CUISINE[lang],
  acceptsReservations: "True",
  sameAs: ["https://www.facebook.com/Landhotel.Schend/", "https://www.booking.com/hotel/de/landhaus-schend.html", "https://www.tripadvisor.com/Hotel_Review-g2298352-d2330477-Reviews-Landhaus_Schend-Immerath_Rhineland_Palatinate.html"],
  potentialAction: { "@type": "ReserveAction", target: { "@type": "EntryPoint", urlTemplate: `${ORIGIN}${localizedPath("/anfrage", lang)}`, actionPlatform: ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"] }, result: { "@type": "FoodEstablishmentReservation", name: "Tischreservierung" } },
  containedInPlace: { "@id": "https://landhaus-schend.de/#hotel" },
  priceRange: "€€",
  image: `https://landhaus-schend.de${SCHEND_RESTAURANT}`,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Hauptstraße 9",
    addressLocality: "Immerath",
    addressRegion: "Rheinland-Pfalz",
    postalCode: "54552",
    addressCountry: "DE",
  },
  geo: { "@type": "GeoCoordinates", latitude: 50.1303, longitude: 6.9594 },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Thursday", "Friday", "Saturday"], opens: "17:30", closes: "20:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Sunday"], opens: "12:00", closes: "14:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Sunday"], opens: "17:30", closes: "20:00" },
  ],
};
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  canonicalPath={localizedPath("/restaurant", lang)}
  lang={lang}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(restaurantSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />

  <!-- HERO -->
  <section class="relative h-[60vh] min-h-[420px] max-h-[680px] overflow-hidden">
    <!-- Vollflächiges Hero-Foto (object-cover wie der Startseiten-Hero), dezenter Ken-Burns-Zoom.
         Früher: object-contain + verwischte Kopie desselben Bildes als Ränder-Füller — ergab eine
         „Briefmarke im Rahmen" (Letterbox) UND lud dasselbe 377-KB-Foto doppelt als LCP. Jetzt
         randvoll, ein einziges Bild. -->
    <Pic src="/fotos/gedeckter-tisch-mit-schnitzelteller-und-wein-landhaus-schend.jpg" alt={c.heroAlt} class="absolute inset-0 w-full h-full object-cover object-center hero-ken-burns" fetchpriority="high" decoding="async" />
    <div aria-hidden="true" class="absolute inset-0 bg-black/30"></div>
    <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-60 bg-gradient-to-t from-black/55 via-black/15 to-transparent"></div>
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6 text-white">
      <div class="flex items-center gap-4 mb-7">
        <span class="block h-px w-12 md:w-20 bg-white/65"></span>
        <span class="text-[11px] md:text-xs font-medium tracking-[0.24em] uppercase text-white/90" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">{c.heroBadge}</span>
        <span class="block h-px w-12 md:w-20 bg-white/65"></span>
      </div>
      <h1 class="headline-reveal font-display text-balance text-[2.5rem] sm:text-5xl md:text-7xl leading-[0.95] mb-5 max-w-3xl" style="text-shadow:0 2px 14px rgba(0,0,0,0.55)">Landhaus Restaurant</h1>
      <p class="font-display-italic text-balance text-white/95 text-lg md:text-2xl max-w-xl leading-snug mb-8" style="text-shadow:0 1px 8px rgba(0,0,0,0.55)">{c.heroSubtitle}</p>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4">
        <a href="tel:+496573306" class="inline-flex items-center justify-center gap-3 px-9 py-4 min-h-[56px] bg-white text-zinc-900 text-xs sm:text-sm font-medium tracking-[0.2em] uppercase rounded-sm hover:bg-secondary hover:text-secondary-foreground transition-colors">
          {c.ctaReserve}
        </a>
        <a href={localizedPath("/", lang)} class="inline-flex items-center justify-center gap-2 px-7 py-4 min-h-[56px] border border-white/60 text-white text-xs sm:text-sm font-medium tracking-[0.2em] uppercase rounded-sm hover:bg-white/10 transition-all" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">{c.ctaHotel}</a>
      </div>
    </div>
  </section>

  <!-- Tagesgäste-Banner -->
  <section class="animate-pulse-banner border-y border-border/60">
    <div class="container mx-auto px-4 py-5 md:py-6 text-center">
      <span class="inline-flex items-center gap-2 text-sm md:text-base font-medium text-foreground">
        <svg class="h-4 w-4 text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
        {c.banner}
      </span>
    </div>
  </section>

  <!-- Drei Spalten -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="grid md:grid-cols-3 gap-px bg-border/50 max-w-5xl mx-auto border border-border/40 rounded-md overflow-hidden shadow-card">
      <div class="bg-background p-8 flex flex-col" data-reveal>
        <h3 class="font-display text-xl md:text-2xl mb-5 leading-tight">{c.hoursH3}</h3>
        <div class="space-y-3 text-sm flex-1">
          <div><p class="font-medium">{c.hoursThuSat}</p><p class="text-muted-foreground">{c.hoursThuSatTime}</p></div>
          <div><p class="font-medium">{c.hoursSun}</p><p class="text-muted-foreground">{c.hoursSunTime1}</p><p class="text-muted-foreground">{c.hoursSunTime2}</p></div>
          <div><p class="font-medium">{c.restDayLabel}</p><p class="text-muted-foreground">{c.restDayText}</p></div>
        </div>
      </div>
      <div class="bg-background p-8 flex flex-col" data-reveal style="--reveal-delay:0.08s">
        <h3 class="font-display text-xl md:text-2xl mb-5 leading-tight">{c.kitchenH3}</h3>
        <ul class="space-y-2.5 text-sm text-muted-foreground flex-1">
          {c.kitchen.map((k) => <li>{k}</li>)}
        </ul>
        <p class="text-xs text-muted-foreground italic mt-5">{c.kitchenNote}</p>
      </div>
      <div class="bg-background p-8 flex flex-col" data-reveal style="--reveal-delay:0.16s">
        <h3 class="font-display text-xl md:text-2xl mb-5 leading-tight">{c.feastH3}</h3>
        <p class="text-sm text-muted-foreground flex-1 leading-relaxed">
          {c.feastText}
        </p>
        <p class="text-xs text-muted-foreground italic mt-5">{c.feastNote}</p>
      </div>
    </div>
  </section>

  <!-- Food-Marquee -->
  <section class="overflow-hidden border-y border-border/60 py-6 bg-muted/20">
    <div class="flex w-max animate-marquee">
      {Array.from({ length: 2 }).flatMap(() =>
        FOOD_PHOTOS.map((src) => (
          <Pic src={src} alt="" aria-hidden="true" loading="lazy" decoding="async" class="h-44 md:h-56 w-auto object-cover rounded-md shadow-card mr-4" />
        )),
      )}
    </div>
  </section>

  <!-- Kontakt / Anfahrt -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16">
      <div data-reveal>
        <p class="eyebrow">{c.reserveEyebrow}</p>
        <h2 class="font-display text-3xl md:text-4xl mt-3 mb-8 leading-tight">{c.reserveH2}</h2>
        <div class="space-y-5">
          <a href="tel:+496573306" class="flex items-center gap-4 group">
            <svg class="h-5 w-5 text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            <span>
              <span class="block text-2xl font-semibold tabular-nums tracking-tight group-hover:text-secondary transition-colors">+49 6573 306</span>
              <span class="block text-sm text-muted-foreground">{c.phoneNote}</span>
            </span>
          </a>
          <a href={`mailto:info@landhaus-schend.de?subject=${encodeURIComponent(c.mailSubject)}`} class="flex items-center gap-4 group">
            <svg class="h-5 w-5 text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
            <span>
              <span class="block font-display text-xl group-hover:text-secondary transition-colors break-all">info@landhaus-schend.de</span>
              <span class="block text-sm text-muted-foreground">{c.mailNote}</span>
            </span>
          </a>
        </div>
      </div>
      <div data-reveal style="--reveal-delay:0.08s">
        <p class="eyebrow">{c.directionsEyebrow}</p>
        <h2 class="font-display text-3xl md:text-4xl mt-3 mb-8 leading-tight">{c.directionsH2}</h2>
        <div class="flex items-start gap-4 mb-6">
          <svg class="h-5 w-5 text-secondary shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <p class="font-display text-xl leading-tight">Hauptstraße 9<br />54552 Immerath</p>
            <p class="text-sm text-muted-foreground mt-1">{c.regionLine}</p>
          </div>
        </div>
        <ul class="space-y-2 text-sm text-muted-foreground">
          {c.distances.map((d) => <li>{d}</li>)}
        </ul>
        <p class="text-[11px] text-muted-foreground mt-2">{c.distancesNote}</p>
        <div class="mt-6">
          <a href="https://www.google.com/maps?q=Landhaus+Schend+Hauptstraße+9+54552+Immerath" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-secondary hover:text-foreground transition-colors underline underline-offset-4 decoration-secondary/40">
            {c.mapsLink}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feiern-Spread -->
  <section class="grid lg:grid-cols-12 items-stretch bg-muted/30">
    <div class="lg:col-span-6">
      <div class="aspect-[4/3] lg:aspect-auto lg:h-full lg:min-h-[480px] overflow-hidden">
        <Pic src="/fotos/festtafel-am-fenster-mit-gartenblick-landhaus-schend-vulkaneifel.jpg" alt={c.spreadAlt} width={1600} height={1200} loading="lazy" decoding="async" class="w-full h-full object-cover" sizes="(min-width: 1024px) 50vw, 100vw" />
      </div>
    </div>
    <div class="lg:col-span-6 px-6 md:px-12 lg:px-16 py-16 md:py-20 flex flex-col justify-center" data-reveal>
      <p class="eyebrow">{c.spreadEyebrow}</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mt-4 mb-6 text-balance leading-tight">{c.spreadH2}</h2>
      <p class="text-foreground/85 leading-relaxed max-w-prose mb-6">
        {c.spreadText}
      </p>
      <!-- Anrufen UND E-Mail nebeneinander: wer abends nicht telefonieren mag,
           kann die Feier-Anfrage trotzdem hier abschließen (mailto als Zweitweg). -->
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 self-start">
        <a href="tel:+496573306" class="inline-flex items-center justify-center gap-3 px-7 py-3.5 min-h-[52px] bg-primary text-primary-foreground rounded-sm text-xs sm:text-sm font-medium tracking-[0.2em] uppercase hover:bg-secondary hover:text-secondary-foreground transition-colors">
          {c.spreadCta}
        </a>
        <a href={`mailto:info@landhaus-schend.de?subject=${encodeURIComponent(c.spreadEyebrow)}`} class="inline-flex items-center justify-center gap-2 px-7 py-3.5 min-h-[52px] border border-foreground/25 text-foreground rounded-sm text-xs sm:text-sm font-medium tracking-[0.2em] uppercase hover:border-secondary hover:text-secondary transition-colors">
          E-Mail
        </a>
      </div>
    </div>
  </section>
</Layout>
