---
// Geteilte „Pakete-Übersicht" (alle Sprachen). Daten lokalisiert aus
// site/i18n/content/pakete.ts (Struktur aus lib/pakete.ts).
import Layout from "../../layouts/Layout.astro";
import Pic from "../Pic.astro";
import { ORIGIN } from "../../lib/site";
import { breadcrumbLd, homeCrumb, itemListLd, fromOffer } from "../../lib/schema";
import { DEFAULT_LOCALE, localizedPath, type Locale } from "../../i18n";
import { paketeFor, paketeChrome } from "../../i18n/content/pakete";

interface Props {
  lang?: Locale;
}
const { lang = DEFAULT_LOCALE } = Astro.props;
const c = paketeChrome[lang];
const pakete = paketeFor(lang);

const stripQ = (s: string) => s.replace(/[„“”"]/g, "");
const breadcrumb = breadcrumbLd(ORIGIN, lang, [homeCrumb(lang), { name: stripQ(c.listH1), path: "/pakete" }]);
// GEO-Q&A der Übersicht — eigene @id/url + andere Fragen als /faq (keine Dubletten).
const paketeUrl = `${ORIGIN}${localizedPath("/pakete", lang)}`;
const faqGraph = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${paketeUrl}#pakete-faq`,
  url: paketeUrl,
  mainEntity: c.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
// ItemList der Pakete; bepreiste als Product mit Offer (lowPrice aus "ab …€"-Zahl).
const paketeList = itemListLd(pakete.map((p) => {
  const url = `${ORIGIN}${localizedPath(`/pakete/${p.slug}`, lang)}`;
  const lowPrice = (p.price?.match(/(\d+)/) || [])[1];
  return {
    url,
    name: stripQ(p.title),
    item: {
      "@type": "Product",
      name: stripQ(p.title),
      url,
      ...(p.cover ? { image: `${ORIGIN}${p.cover}` } : {}),
      ...(lowPrice
        ? { offers: fromOffer(Number(lowPrice), { url: `${ORIGIN}${localizedPath("/anfrage", lang)}`, seller: { "@id": "https://landhaus-schend.de/#hotel" } }) }
        : {}),
    },
  };
}));
---

<Layout
  title={c.listMetaTitle}
  description={c.listMetaDescription}
  canonicalPath={localizedPath("/pakete", lang)}
  lang={lang}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(paketeList)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqGraph)} />
  <section class="container mx-auto px-4 pt-12 md:pt-16 pb-20">
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <p class="eyebrow">{c.listEyebrow}</p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mt-3 text-balance leading-[1.05]">
        {c.listH1}
      </h1>
      <p class="text-muted-foreground mt-5 leading-relaxed text-pretty">
        {c.listIntro}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {pakete.map((p, i) => (
        <a href={localizedPath(`/pakete/${p.slug}`, lang)} class="spotlight group flex flex-col rounded-md overflow-hidden border border-border bg-card shadow-card hover:shadow-elevated transition-shadow" data-reveal style={`--reveal-delay:${(i % 3) * 0.08}s`}>
          <div class="aspect-[4/3] overflow-hidden">
            <Pic src={p.cover} alt={p.coverAlt ?? p.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="flex flex-col flex-1 p-6">
            <h2 class="font-display text-2xl leading-snug group-hover:text-secondary transition-colors text-balance">{p.title}</h2>
            <p class="text-sm text-muted-foreground mt-3 leading-relaxed flex-1 text-pretty">{p.intro}</p>
            <div class="mt-5 flex items-center justify-between">
              {p.price ? <span class="font-display text-secondary text-lg">{p.price}</span> : <span></span>}
              <span class="text-xs font-semibold tracking-wide uppercase text-primary group-hover:text-secondary transition-colors">{c.detailsCta}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- GEO-Q&A (eigene Fragen, separat von /faq) -->
  <section class="bg-gradient-to-b from-muted/15 via-background to-muted/15">
    <div class="container mx-auto px-4 py-16 md:py-24 max-w-3xl">
      <div class="text-center mb-12 md:mb-14">
        <span class="hairline block max-w-[3rem] mx-auto mb-6"></span>
        <h2 class="font-display text-3xl md:text-4xl text-balance">{c.faqH2}</h2>
      </div>
      <div class="border-t border-border/70">
        {c.faq.map((f, i) => (
          <details class="faq-item border-b border-border/70" open={i === 0}>
            <summary class="flex items-start justify-between gap-5 py-6 cursor-pointer list-none group">
              <span class="font-display text-lg md:text-xl leading-snug text-balance pt-0.5 group-hover:text-secondary transition-colors">{f.q}</span>
              <svg class="faq-chevron shrink-0 mt-1.5 h-4 w-4 text-secondary transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <p class="pb-6 pr-8 text-foreground/85 leading-relaxed max-w-prose">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
    <style>
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-item[open] .faq-chevron { transform: rotate(180deg); }
    </style>
  </section>
</Layout>
