---
// Vanilla-Lightbox als Progressive Enhancement (kein Framework, bleibt SSG/Zero-JS-Default).
// Jedes <img data-lightbox="GRUPPE"> wird klickbar; Klick/Enter öffnet ein Vollbild-Overlay,
// Pfeile/Wischen blättern innerhalb der Gruppe, Esc/Klick-außen schließt. Ohne JS bleiben es
// normale Bild-Kacheln (Inhalt + GEO unberührt).
// Body-level gerendert → kein backdrop-filter/transform-Vorfahr, der fixed einsperrt
// ([[backdrop-filter-traps-fixed-portal-gotcha]]).
import { localeFromPath, type Locale } from "../i18n";

interface Props {
  lang?: Locale;
}
// Locale aus dem Pfad ableiten (Galerie ist die einzige Seite mit aktivem Trigger,
// z.B. "/en/galerie" → en) — ein durchgereichtes lang-Prop hat Vorrang.
const { lang = localeFromPath(Astro.url.pathname) } = Astro.props;

// Lokale Übersetzungen der Bedien-Labels (Screenreader-Chrome). Deutsche Ausgabe
// bleibt 1:1 wie zuvor; EN/FR/NL bekommen je Locale die passende Ansage (WCAG 3.1.2).
type L = Record<Locale, string>;
const LB: Record<"view" | "close" | "prev" | "next", L> = {
  view: { de: "Bildansicht", en: "Image view", fr: "Affichage de l’image", nl: "Afbeeldingsweergave" },
  close: { de: "Schließen", en: "Close", fr: "Fermer", nl: "Sluiten" },
  prev: { de: "Vorheriges Bild", en: "Previous image", fr: "Image précédente", nl: "Vorige afbeelding" },
  next: { de: "Nächstes Bild", en: "Next image", fr: "Image suivante", nl: "Volgende afbeelding" },
};
const lb = (key: keyof typeof LB): string => LB[key][lang] ?? LB[key].de;
---

<div
  id="lightbox"
  class="fixed inset-0 z-[120] hidden items-center justify-center"
  role="dialog"
  aria-modal="true"
  aria-label={lb("view")}
  data-open="false"
>
  <div data-lb-backdrop class="absolute inset-0 bg-[hsl(220_22%_8%)]/92 backdrop-blur-sm"></div>

  <figure class="relative z-10 m-0 flex flex-col items-center gap-4 px-4 max-w-[92vw]">
    <img
      data-lb-img
      alt=""
      class="lb-image max-h-[80vh] max-w-full w-auto h-auto rounded-sm shadow-[0_24px_70px_rgba(0,0,0,0.55)] ring-1 ring-[hsl(38_55%_60%)]/30"
    />
    <figcaption data-lb-cap class="font-display text-base md:text-lg text-[hsl(38_30%_92%)] text-center max-w-2xl"></figcaption>
  </figure>

  <button data-lb-close type="button" aria-label={lb("close")} class="lb-btn absolute top-4 right-4 z-20">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <button data-lb-prev type="button" aria-label={lb("prev")} class="lb-btn absolute left-2 md:left-5 top-1/2 -translate-y-1/2 z-20">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
  </button>
  <button data-lb-next type="button" aria-label={lb("next")} class="lb-btn absolute right-2 md:right-5 top-1/2 -translate-y-1/2 z-20">
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
  </button>
  <div data-lb-count class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 text-[11px] tracking-[0.22em] uppercase text-[hsl(38_30%_92%)]/70 tabular-nums"></div>
</div>

<style>
  #lightbox[data-open="true"] { display: flex; }

  .lb-btn {
    display: grid;
    place-items: center;
    height: 2.75rem;
    width: 2.75rem;
    border-radius: 9999px;
    background: hsl(220 22% 13% / 0.65);
    color: hsl(38 30% 92%);
    transition: background-color 0.2s, color 0.2s;
  }
  .lb-btn:hover { background: hsl(220 22% 13%); color: hsl(38 55% 62%); }

  #lightbox[data-open="true"] figure { animation: lb-in 0.32s cubic-bezier(0.22, 1, 0.36, 1); }
  @keyframes lb-in { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: none; } }

  /* Klickbare Bilder bekommen einen Zoom-Cursor (nur wo JS die Trigger verkabelt). */
  :global([data-lightbox]) { cursor: zoom-in; }

  @media (prefers-reduced-motion: reduce) {
    #lightbox[data-open="true"] figure { animation: none; }
  }
</style>

<script>
  (function () {
    const lb = document.getElementById("lightbox");
    if (!lb) return;
    const triggers = Array.from(document.querySelectorAll("[data-lightbox]"));
    if (!triggers.length) return; // Seite ohne Galerie → Overlay bleibt unsichtbar/inert

    const imgEl = lb.querySelector("[data-lb-img]") as HTMLImageElement;
    const capEl = lb.querySelector("[data-lb-cap]") as HTMLElement;
    const countEl = lb.querySelector("[data-lb-count]") as HTMLElement;
    const btnClose = lb.querySelector("[data-lb-close]") as HTMLButtonElement;
    const btnPrev = lb.querySelector("[data-lb-prev]") as HTMLButtonElement;
    const btnNext = lb.querySelector("[data-lb-next]") as HTMLButtonElement;

    const groups: Record<string, HTMLElement[]> = {};
    triggers.forEach((el) => {
      const g = el.getAttribute("data-lightbox") || "default";
      (groups[g] ||= []).push(el as HTMLElement);
      el.setAttribute("role", "button");
      el.setAttribute("tabindex", "0");
    });

    let current: { src: string; alt: string }[] = [];
    let idx = 0;
    let lastFocus: HTMLElement | null = null;

    const render = () => {
      const item = current[idx];
      if (!item) return;
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      capEl.textContent = item.alt;
      capEl.style.display = item.alt ? "" : "none";
      const multi = current.length > 1;
      countEl.textContent = multi ? `${idx + 1} / ${current.length}` : "";
      btnPrev.style.display = multi ? "" : "none";
      btnNext.style.display = multi ? "" : "none";
    };

    const open = (groupName: string, startIdx: number) => {
      current = groups[groupName].map((el) => ({
        src: el.getAttribute("data-lb-full") || (el as HTMLImageElement).currentSrc || (el as HTMLImageElement).src,
        alt: el.getAttribute("alt") || "",
      }));
      idx = startIdx;
      lastFocus = document.activeElement as HTMLElement;
      lb.dataset.open = "true";
      document.documentElement.style.overflow = "hidden";
      try { (window as any).__lenis && (window as any).__lenis.stop(); } catch (e) {}
      render();
      btnClose.focus();
    };

    const close = () => {
      lb.dataset.open = "false";
      document.documentElement.style.overflow = "";
      try { (window as any).__lenis && (window as any).__lenis.start(); } catch (e) {}
      imgEl.removeAttribute("src");
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    };

    const step = (d: number) => {
      if (current.length < 2) return;
      idx = (idx + d + current.length) % current.length;
      render();
    };

    triggers.forEach((el) => {
      const g = el.getAttribute("data-lightbox") || "default";
      const startIdx = groups[g].indexOf(el as HTMLElement);
      el.addEventListener("click", (e) => { e.preventDefault(); open(g, startIdx); });
      el.addEventListener("keydown", (e) => {
        const ke = e as KeyboardEvent;
        if (ke.key === "Enter" || ke.key === " ") { e.preventDefault(); open(g, startIdx); }
      });
    });

    btnClose.addEventListener("click", close);
    (lb.querySelector("[data-lb-backdrop]") as HTMLElement).addEventListener("click", close);
    btnPrev.addEventListener("click", () => step(-1));
    btnNext.addEventListener("click", () => step(1));

    document.addEventListener("keydown", (e) => {
      if (lb.dataset.open !== "true") return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") step(-1);
      else if (e.key === "ArrowRight") step(1);
      else if (e.key === "Tab") {
        // Simpler Fokus-Trap: hält den Fokus innerhalb des Overlays.
        const f = Array.from(lb.querySelectorAll("button")).filter(
          (b) => (b as HTMLElement).style.display !== "none",
        ) as HTMLElement[];
        if (!f.length) return;
        const first = f[0], last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    // Wischen (Touch/Pointer)
    let sx = 0;
    lb.addEventListener("pointerdown", (e) => { sx = (e as PointerEvent).clientX; });
    lb.addEventListener("pointerup", (e) => {
      if (lb.dataset.open !== "true") return;
      const dx = (e as PointerEvent).clientX - sx;
      if (Math.abs(dx) > 50) step(dx < 0 ? 1 : -1);
    });
  })();
</script>
