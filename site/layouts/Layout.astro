---
// Basis-Layout für alle öffentlichen Astro-Seiten.
// Erzeugt den kompletten SEO-Head STATISCH (kein JS nötig) — spiegelt den
// Vertrag aus src/hooks/useSEO.ts + index.html der Vite-App:
//   fullTitle = "<title> | Landhaus Schend"
//   description → meta + og:description + twitter:description
//   canonical = ORIGIN + canonicalPath, og:url = canonical
//   robots je nach noindex
// Per-Seite-JSON-LD kommt über <slot name="head" /> (z.B. FAQPage auf /faq).
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import A11yPanel from "../components/A11yPanel.astro";
import StickyCTA from "../components/StickyCTA.astro";
import Lightbox from "../components/Lightbox.astro";
import { ORIGIN, SITE_NAME } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath: string; // z.B. "/impressum" (führender Slash)
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  lang?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogImage = "/fotos/hotelfront-mit-rosen-landhaus-schend-vulkaneifel.jpg",
  ogType = "website",
  noindex = false,
  lang = "de",
} = Astro.props;

const fullTitle = title
  ? `${title} | ${SITE_NAME}`
  : `${SITE_NAME} – 3-Sterne-Superior Hotel in der Vulkaneifel`;

const canonical = `${ORIGIN}${canonicalPath}`;
const ogImageAbs = ogImage.startsWith("http") ? ogImage : `${ORIGIN}${ogImage}`;
const robots = noindex
  ? "noindex, nofollow"
  : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="author" content="Landhaus Schend" />
    <meta name="robots" content={robots} />

    <!-- Default = hell; JS hält theme-color beim Umschalten synchron (SiteHeader). -->
    <meta name="theme-color" content="#f8f1e3" />
    <meta name="color-scheme" content="dark light" />
    <meta name="geo.region" content="DE-RP" />
    <meta name="geo.placename" content="Immerath, Vulkaneifel" />
    <meta name="geo.position" content="50.1303;6.9594" />
    <meta name="ICBM" content="50.1303, 6.9594" />

    <link rel="canonical" href={canonical} />
    {/* Voll-reziproke hreflang (en/fr/nl als echte Pfade) kommen in Stufe 3. */}
    <link rel="alternate" hreflang="de" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    {/* Theme vor Render anwenden — verhindert Flash beim Light/Dark-Wechsel. */}
    <script is:inline>
      (function () {
        // Früh markieren, dass JS läuft — so starten Reveal-/Timeline-Elemente
        // schon vor dem ersten Paint verborgen (kein Aufblitzen). Ohne JS bleibt
        // die Klasse aus → alle Inhalte voll sichtbar.
        document.documentElement.classList.add("has-js");
        // Gemeinsame Scroll-Brücke: scroll-abhängige Effekte (Header-Glas,
        // Hero-Parallax) registrieren sich hier und werden unten von Lenis
        // (weiches Scrollen) ODER nativem Scroll gespeist — nie direkt an
        // window-"scroll", denn das feuert Lenis nicht ([[lenis-no-native-scroll-event-gotcha]]).
        window.__scrollSubs = [];
        window.__onScroll = function (cb) {
          window.__scrollSubs.push(cb);
          try { cb(window.scrollY || 0); } catch (e) {}
        };
        try {
          // Default = HELL (überall, Desktop+Mobil). Nur eine ausdrückliche
          // Dunkel-Wahl ("dark") verdunkelt — sonst immer hell, unabhängig vom OS.
          var t = localStorage.getItem("theme");
          if (t === "dark") document.documentElement.classList.add("dark");
          else if (t !== "system") document.documentElement.classList.add("light");
        } catch (e) {}
        // Barrierefreiheits-Komfort (Schriftgröße/Kontrast/Bewegung) früh anwenden,
        // damit kein Umspringen beim Laden sichtbar ist. Key: schend_a11y_v1.
        try {
          var a = JSON.parse(localStorage.getItem("schend_a11y_v1") || "{}");
          var r = document.documentElement;
          if (a.font === "large") r.classList.add("a11y-large");
          if (a.font === "larger") r.classList.add("a11y-larger");
          if (a.contrast) r.classList.add("a11y-high-contrast");
          if (a.motion) r.classList.add("a11y-reduced-motion");
        } catch (e) {}
      })();
    </script>

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <meta name="apple-mobile-web-app-title" content="Schend" />

    {/* Self-hosted Fonts (DSGVO: kein Google-CDN). woff2 + fonts.css in /public/fonts. */}
    <link rel="preload" href="/fonts/inter-UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Landhaus Schend" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:image:alt" content="Landhaus Schend in Immerath, Vulkaneifel" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageAbs} />

    <slot name="head" />

    <!-- Marken-Splash: dunkler Vorhang beim ersten Betreten der Seite (deckt FOUC/
         Flash zu), Schend-Marke + Wortmarke + 0→100 %-Zähler, dann Reveal.
         Erscheint NUR beim ersten Reinkommen ODER beim Aktualisieren (Reload) —
         bei interner Navigation zwischen Seiten übersprungen (Referrer = gleiche
         Domain). Entscheidung vor dem Paint, damit kein dunkler Deckel aufblitzt.
         ?splash erzwingt ihn (zum Testen). -->
    <script is:inline>
      (function () {
        try {
          var d = document.documentElement;
          // ?splash erzwingt den Splash (zum Testen) und schlägt alles andere.
          if (/[?&#]splash\b/.test(location.href)) return;
          // Such-Crawler + Lab-Tools (Lighthouse/PageSpeed/Headless/Preview-Bots)
          // bekommen KEINEN Splash -> kein LCP-Verlust, kein verdeckter Inhalt.
          var ua = navigator.userAgent || "";
          var isBot = /bot|crawl|spider|slurp|lighthouse|pagespeed|headless|gtmetrix|pingdom|mediapartners|facebookexternalhit|embedly|whatsapp|telegram|preview/i.test(ua);
          if (isBot) { d.classList.add("splash-skip"); return; }
          // Eugen-Wunsch 20.06.: Splash NUR beim ersten Betreten der Seite ODER beim
          // Aktualisieren (Reload) — NICHT bei interner Navigation (nervt sonst).
          var navType = "";
          try {
            var navEntry = performance.getEntriesByType && performance.getEntriesByType("navigation")[0];
            navType = navEntry ? navEntry.type
              : (performance.navigation && performance.navigation.type === 1 ? "reload" : "");
          } catch (e) {}
          var isReload = navType === "reload";
          // Interne Navigation = von einer Seite derselben Domain gekommen.
          var fromSameSite = false;
          try { fromSameSite = !!document.referrer && new URL(document.referrer).host === location.host; } catch (e) {}
          if (fromSameSite && !isReload) d.classList.add("splash-skip");
        } catch (e) {}
      })();
    </script>
    <style is:inline>
      #splash {
        position: fixed; inset: 0; z-index: 200;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: clamp(1.1rem, 4vw, 1.9rem);
        background: hsl(220 24% 9%); color: hsl(38 32% 92%);
        opacity: 1; transition: opacity .55s ease;
        animation: splash-failsafe 0s linear 5s forwards; /* falls JS ausfällt */
      }
      html.splash-skip #splash { display: none !important; }
      #splash.is-done { opacity: 0; pointer-events: none; }
      .splash-stars { display: flex; gap: clamp(.35rem, 2vw, .6rem); margin-bottom: -.3rem; }
      .splash-star {
        width: clamp(16px, 4.6vw, 22px); height: auto;
        color: hsl(38 48% 66%); fill: currentColor;
        opacity: 0; transform: translateY(7px) scale(.55);
        animation: splash-star-in .55s cubic-bezier(.22,1,.36,1) forwards;
      }
      .splash-star { animation-duration: .65s; }
      .splash-star:nth-child(1) { animation-delay: .25s; }
      .splash-star:nth-child(2) { animation-delay: .6s; }
      .splash-star:nth-child(3) { animation-delay: .95s; }
      @keyframes splash-star-in { to { opacity: 1; transform: none; } }
      .splash-mark {
        height: clamp(62px, 15vw, 112px); width: auto; aspect-ratio: 2048 / 871;
        -webkit-mask: url("/schend-mark.png") center / contain no-repeat;
                mask: url("/schend-mark.png") center / contain no-repeat;
        background: hsl(38 32% 92%);
        opacity: 0; transform: translateY(10px) scale(.97);
        animation: splash-mark-in .9s cubic-bezier(.22,1,.36,1) .1s forwards;
      }
      .splash-word {
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(1.45rem, 6vw, 2.5rem); font-weight: 500;
        text-transform: uppercase; color: hsl(38 48% 70%);
        white-space: nowrap; letter-spacing: .5em;
        opacity: 0; filter: blur(9px);
        animation: splash-word-in 1.2s cubic-bezier(.22,1,.36,1) .7s forwards;
      }
      .splash-bar {
        width: clamp(140px, 42vw, 220px); height: 2px; margin-top: .2rem;
        background: hsl(38 32% 92% / .15); border-radius: 999px; overflow: hidden;
      }
      .splash-fill { display: block; height: 100%; width: 0%; background: hsl(38 48% 64%); }
      .splash-pct {
        font-variant-numeric: tabular-nums; font-size: .7rem;
        letter-spacing: .28em; color: hsl(38 32% 92% / .55);
      }
      @keyframes splash-mark-in { to { opacity: 1; transform: none; } }
      @keyframes splash-word-in { to { opacity: 1; filter: blur(0); letter-spacing: .2em; } }
      @keyframes splash-failsafe { to { opacity: 0; visibility: hidden; pointer-events: none; } }
      @media (prefers-reduced-motion: reduce) {
        .splash-mark, .splash-word { animation: none; opacity: 1; filter: none; transform: none; letter-spacing: .2em; }
      }
    </style>
  </head>

  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <div id="splash" role="presentation">
      <span class="splash-stars" aria-hidden="true">
        <svg class="splash-star" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <svg class="splash-star" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <svg class="splash-star" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </span>
      <span class="splash-mark" aria-hidden="true"></span>
      <span class="splash-word">Landhaus Schend</span>
      <div class="splash-bar" aria-hidden="true"><span class="splash-fill"></span></div>
      <span class="splash-pct" aria-hidden="true">0&thinsp;%</span>
    </div>
    <script is:inline>
      (function () {
        var el = document.getElementById("splash");
        if (!el || getComputedStyle(el).display === "none") return; // übersprungen
        var pct = el.querySelector(".splash-pct");
        var fill = el.querySelector(".splash-fill");
        var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        var finish = function () {
          el.classList.add("is-done");
          setTimeout(function () { el.remove(); }, 600);
        };
        // Splash ~2 s sichtbar (Desktop + Mobil), dann sanfter Reveal aufs Hero.
        if (reduce) {
          if (pct) pct.textContent = "100 %";
          if (fill) fill.style.width = "100%";
          setTimeout(finish, 2800);
          return;
        }
        var t0 = null, DUR = 2300, ended = false;
        var safety = setTimeout(function () { if (!ended) { ended = true; finish(); } }, 5500);
        function step(now) {
          if (t0 === null) t0 = now;
          var p = Math.min(1, (now - t0) / DUR);
          var v = Math.round((1 - Math.pow(1 - p, 2)) * 100); // ease-out
          if (pct) pct.textContent = v + " %";
          if (fill) fill.style.width = v + "%";
          if (p < 1) requestAnimationFrame(step);
          else if (!ended) { ended = true; clearTimeout(safety); setTimeout(finish, 600); } // 100 % halten -> Fade bei ~2,9 s
        }
        requestAnimationFrame(step);
      })();
    </script>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <div id="reading-progress" aria-hidden="true" class="fixed top-0 inset-x-0 h-[2px] z-[60] pointer-events-none">
      <div class="reading-progress-fill h-full bg-secondary origin-left" style="transform:scaleX(0);transition:transform 80ms linear"></div>
    </div>
    <SiteHeader />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <SiteFooter />
    <StickyCTA />
    <A11yPanel />
    <Lightbox />

    <style is:global>
      /* Skip-Link — visuell versteckt bis Tastatur-Fokus (a11y). */
      .skip-link {
        position: fixed;
        top: -100px;
        left: 1rem;
        z-index: 100;
        padding: 0.6rem 1rem;
        border-radius: 0.4rem;
        background: hsl(var(--primary));
        color: hsl(var(--primary-foreground));
        font-size: 0.875rem;
        font-weight: 600;
        transition: top 0.2s ease;
      }
      .skip-link:focus {
        top: 1rem;
      }

      /* Scroll-Reveal als Progressive Enhancement: Ohne JS bleiben Elemente
         voll sichtbar (Inhalt + GEO unberührt). Erst wenn JS läuft (html.has-js)
         starten [data-reveal]-Elemente verborgen und faden beim Reinscrollen ein.
         --reveal-delay erlaubt gestaffelte Karten. */
      html.has-js [data-reveal] {
        opacity: 0;
        transform: translateY(26px);
        transition:
          opacity 0.8s ease-out,
          transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--reveal-delay, 0s);
        will-change: opacity, transform;
      }
      html.has-js [data-reveal].in {
        opacity: 1;
        transform: none;
      }
      @media (prefers-reduced-motion: reduce) {
        html.has-js [data-reveal] {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }
      /* „Bewegung reduzieren" im Komfort-Tool zeigt alle Reveal-Elemente sofort. */
      html.a11y-reduced-motion [data-reveal] {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      /* Timeline (Über-uns) ohne JS bzw. bei reduzierter Bewegung voll sichtbar. */
      html:not(.has-js) .tl-item,
      html.a11y-reduced-motion .tl-item {
        opacity: 1 !important;
        transform: none !important;
      }
      html:not(.has-js) .tl-line,
      html.a11y-reduced-motion .tl-line {
        transform: scaleX(1) !important;
      }
      /* Magnetische Buttons — sanfte Rückkehr nach dem Loslassen. */
      .magnetic { transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1); }

      /* Lenis (weiches Scrollen) — empfohlene Basis-Styles. Lenis setzt die
         Klassen .lenis/.lenis-smooth automatisch auf <html>. */
      html.lenis,
      html.lenis body { height: auto; }
      .lenis.lenis-smooth { scroll-behavior: auto !important; }
      .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
      .lenis.lenis-stopped { overflow: hidden; }
      .lenis.lenis-smooth iframe { pointer-events: none; }
    </style>

    <script>
      import Lenis from "lenis";
      // Progressive Enhancement für alle Effekte. Inhalt steht ohne JS im HTML;
      // dieses Script legt nur die Animationen obendrauf (klein, vanilla, kein React).
      // html.has-js wird bereits im Kopf gesetzt.
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const hasIO = "IntersectionObserver" in window;

      // 1) Scroll-Reveal — [data-reveal] fadet beim Reinscrollen ein.
      const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if (reduce || !hasIO) {
        reveals.forEach((el) => el.classList.add("in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                (e.target as HTMLElement).classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
        );
        reveals.forEach((el) => io.observe(el));
        requestAnimationFrame(() => {
          reveals.forEach((el) => {
            if (el.getBoundingClientRect().top < window.innerHeight * 0.92) el.classList.add("in");
          });
        });
      }

      // 2) Timeline-Reveal — Linie zeichnet sich, Jahre faden gestaffelt, Gold-Funke wandert.
      const tls = document.querySelectorAll<HTMLElement>(".tl-reveal");
      if (reduce || !hasIO) {
        tls.forEach((t) => t.classList.add("visible"));
      } else {
        const tio = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("visible");
                tio.unobserve(e.target);
              }
            });
          },
          { threshold: 0.2 },
        );
        tls.forEach((t) => tio.observe(t));
      }

      // 3) Spotlight — sanfter Gold-Schimmer folgt der Maus über Karten.
      if (!reduce) {
        document.querySelectorAll<HTMLElement>(".spotlight").forEach((card) => {
          card.addEventListener("pointermove", (e) => {
            const r = card.getBoundingClientRect();
            card.style.setProperty("--mx", `${((e.clientX - r.left) / r.width) * 100}%`);
            card.style.setProperty("--my", `${((e.clientY - r.top) / r.height) * 100}%`);
          });
        });
      }

      // 4) Tilt — Karten mit .tilt-card kippen leicht in 3D zur Maus.
      if (!reduce && window.matchMedia("(hover: hover)").matches) {
        document.querySelectorAll<HTMLElement>(".tilt-card").forEach((card) => {
          card.addEventListener("pointermove", (e) => {
            const r = card.getBoundingClientRect();
            const px = (e.clientX - r.left) / r.width - 0.5;
            const py = (e.clientY - r.top) / r.height - 0.5;
            card.style.setProperty("--tilt-y", `${px * 6}deg`);
            card.style.setProperty("--tilt-x", `${-py * 6}deg`);
          });
          card.addEventListener("pointerleave", () => {
            card.style.setProperty("--tilt-y", "0deg");
            card.style.setProperty("--tilt-x", "0deg");
          });
        });

        // 4b) Magnetische Buttons — .magnetic folgt sanft dem Cursor.
        document.querySelectorAll<HTMLElement>(".magnetic").forEach((el) => {
          el.addEventListener("pointermove", (e) => {
            const r = el.getBoundingClientRect();
            const x = Math.max(-12, Math.min(12, (e.clientX - (r.left + r.width / 2)) * 0.25));
            const y = Math.max(-10, Math.min(10, (e.clientY - (r.top + r.height / 2)) * 0.25));
            el.style.transform = `translate(${x}px, ${y}px)`;
          });
          el.addEventListener("pointerleave", () => {
            el.style.transform = "";
          });
        });
      }

      // 5) Weiches Scrollen (Lenis) + zentrale Scroll-Brücke.
      //    Lenis macht das Scroll-Gefühl sanft (wie in V1). Alle scroll-abhängigen
      //    Effekte (Header-Glas, Hero-Parallax, [data-parallax]) hängen an
      //    window.__onScroll, NICHT an window-"scroll" (das feuert Lenis nicht).
      //    Mobil: natives Scrollen (Lenis-Default smoothTouch:false) — am Handy am besten.
      //    Bei reduzierter Bewegung (Komfort-Tool / prefers-reduced-motion) bleibt es nativ.
      const motionOff =
        reduce || document.documentElement.classList.contains("a11y-reduced-motion");
      // Lenis (weiches Scrollen) nur auf Desktop — mobil natives Scrollen (leichter, kein Lib-Overhead).
      const bigScreen = window.matchMedia("(min-width: 768px)").matches;
      const emit = (y: number) => {
        ((window as any).__scrollSubs || []).forEach((cb: (n: number) => void) => {
          try { cb(y); } catch {}
        });
      };
      if (!motionOff && bigScreen) {
        const lenis = new Lenis({ lerp: 0.09, smoothWheel: true, anchors: true });
        (window as any).__lenis = lenis;
        lenis.on("scroll", (e: any) => emit(e.scroll));
        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      } else {
        let ticking = false;
        window.addEventListener(
          "scroll",
          () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
              emit(window.scrollY);
              ticking = false;
            });
          },
          { passive: true },
        );
      }
      emit(window.scrollY || 0);

      // [data-parallax]-Elemente (falls genutzt) — sanfter Versatz, nur Desktop.
      const parallax = document.querySelectorAll<HTMLElement>("[data-parallax]");
      if (!reduce && parallax.length && window.innerWidth >= 768) {
        (window as any).__onScroll((y: number) =>
          parallax.forEach((el) => {
            el.style.transform = `translate3d(0, ${y * 0.18}px, 0)`;
          }),
        );
      }

      // 6) Reading-Progress — 2px Brass-Linie oben, folgt der Scroll-Position (Lenis-Brücke).
      const rpFill = document.querySelector<HTMLElement>(".reading-progress-fill");
      if (rpFill) {
        (window as any).__onScroll((y: number) => {
          const docH = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docH > 0 ? Math.max(0, Math.min(1, y / docH)) : 0;
          rpFill.style.transform = `scaleX(${pct})`;
        });
      }

      // 7) CountUp — Zahlen mit [data-count-to] zählen hoch (beim Mount oder beim Scroll-in).
      //    Attribute: data-count-to, -decimals, -dur, -delay, -mount="1" (above-the-fold).
      (function () {
        const fmt = (v: number, dec: number) =>
          dec === 0 ? Math.round(v).toString() : v.toFixed(dec).replace(".", ",");
        const run = (el: HTMLElement) => {
          if (el.dataset.counted) return;
          el.dataset.counted = "1";
          const to = parseFloat(el.dataset.countTo || "0");
          const dec = parseInt(el.dataset.countDecimals || "0", 10);
          const dur = parseInt(el.dataset.countDur || "1400", 10);
          if (reduce || isNaN(to)) { el.textContent = fmt(to, dec); return; }
          const t0 = performance.now();
          const stepFn = (now: number) => {
            const t = Math.min(1, (now - t0) / dur);
            el.textContent = fmt(to * (1 - Math.pow(1 - t, 3)), dec);
            if (t < 1) requestAnimationFrame(stepFn);
            else el.textContent = fmt(to, dec);
          };
          requestAnimationFrame(stepFn);
        };
        document.querySelectorAll<HTMLElement>("[data-count-to]").forEach((el) => {
          if (el.dataset.countMount === "1") {
            window.setTimeout(() => run(el), parseInt(el.dataset.countDelay || "0", 10));
          } else {
            const obs = new IntersectionObserver(
              (entries) => {
                entries.forEach((e) => {
                  if (e.isIntersecting) {
                    const d = parseInt(el.dataset.countDelay || "0", 10);
                    if (d > 0) window.setTimeout(() => run(el), d);
                    else run(el);
                    obs.disconnect();
                  }
                });
              },
              { threshold: 0.35, rootMargin: "0px 0px -10% 0px" },
            );
            obs.observe(el);
          }
        });
      })();
    </script>
  </body>
</html>
