---
// Schlanke Hülle für Text-lastige Seiten (Recht etc.): Layout + zentrierte
// Lesespalte + Eyebrow + H1. Inhalt kommt über den Default-Slot, optionales
// JSON-LD über <slot name="head" />.
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  noindex?: boolean;
  eyebrow?: string;
  heading: string;
}

const { title, description, canonicalPath, noindex = false, eyebrow = "Rechtliches", heading } = Astro.props;
---

<Layout title={title} description={description} canonicalPath={canonicalPath} noindex={noindex}>
  <slot name="head" slot="head" />
  <div class="container mx-auto px-4 pt-12 md:pt-16 pb-20 max-w-3xl">
    <p class="eyebrow mb-4">{eyebrow}</p>
    <h1 class="font-display text-4xl md:text-5xl mb-12 text-balance leading-[1.05]">{heading}</h1>
    <div class="space-y-10 text-foreground/90 leading-relaxed [&_h2]:font-display [&_h2]:text-xl [&_h2]:md:text-2xl [&_h2]:mb-3 [&_h3]:font-semibold [&_h3]:mt-4 [&_h3]:mb-1 [&_a]:text-secondary [&_a:hover]:underline [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mt-2 [&_ul]:space-y-1">
      <slot />
    </div>
  </div>
</Layout>
