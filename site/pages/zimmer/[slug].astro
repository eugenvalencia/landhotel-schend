---
// Deutsches Zimmer-Detail (Root, /zimmer/[slug]). Inhalt: components/pages/ZimmerDetailPage.astro.
import { ROOM_TYPES } from "../../lib/rooms";
import ZimmerDetailPage from "../../components/pages/ZimmerDetailPage.astro";

export function getStaticPaths() {
  return ROOM_TYPES.map((r) => ({ params: { slug: r.slug } }));
}
const { slug } = Astro.params;
---

<ZimmerDetailPage lang="de" slug={slug!} />
