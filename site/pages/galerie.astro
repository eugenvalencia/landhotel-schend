---
// Galerie — eigene Seite (wie Original-Menü). Alle Bilder self-hosted aus
// /public/fotos. Masonry-Layout via CSS-Columns, beschreibende Alt-Texte (a11y/SEO).
import Layout from "../layouts/Layout.astro";
import Pic from "../components/Pic.astro";
import dimsJson from "../lib/foto-dims.json";
const dims = dimsJson as Record<string, [number, number]>;

const FOTOS = [
  { src: "/fotos/hotelfront-mit-rosen-landhaus-schend-vulkaneifel.jpg", alt: "Hotelfront des Landhaus Schend mit roten Rosen im Sommer" },
  { src: "/fotos/hotelgarten-mit-brunnen-landhaus-schend.jpg", alt: "Hotelgarten mit Brunnen" },
  { src: "/fotos/eingang-mit-torbogen-und-hortensien-landhaus-schend.jpg", alt: "Eingang mit Torbogen und Hortensien" },
  { src: "/fotos/innenhof-mit-balkonen-landhaus-schend-vulkaneifel.jpg", alt: "Innenhof mit blumengeschmückten Balkonen" },
  { src: "/fotos/sonnenterrasse-mit-hortensien-landhaus-schend-vulkaneifel.jpg", alt: "Sonnenterrasse mit Hortensien" },
  { src: "/fotos/gartenseite-mit-terrasse-landhaus-schend.jpg", alt: "Gartenseite mit Terrasse" },
  { src: "/fotos/restaurant-panorama-1-landhaus-schend.jpg", alt: "Landhaus Restaurant — Gastraum" },
  { src: "/fotos/restaurant-panorama-2-landhaus-schend.jpg", alt: "Landhaus Restaurant — gemütliche Atmosphäre" },
  { src: "/fotos/restaurant-panorama-3-landhaus-schend.jpg", alt: "Landhaus Restaurant — Tische und Terrasse" },
  // Feiern & Festsaal — neue Aufnahmen 2026 (beschreibende Alt-Texte für SEO/GEO)
  { src: "/fotos/festsaal-50er-geburtstag-schwarz-gold-landhaus-schend-vulkaneifel.jpg", alt: "Festsaal im Landhaus Schend festlich dekoriert für eine 50er-Geburtstagsfeier in Schwarz-Gold mit Ballonbogen" },
  { src: "/fotos/restaurant-grosser-speisesaal-landhaus-schend.jpg", alt: "Großer Speisesaal im Landhaus Schend mit festlich gedeckten Tafeln und Fensterfront" },  { src: "/fotos/festtafel-gedeck-schwarz-gold-mit-goldlaeufer-landhaus-schend.jpg", alt: "Eingedeckte Festtafel im Landhaus Schend mit goldenem Tischläufer, schwarzen Servietten und Sektgläsern" },
  { src: "/fotos/festtafel-weiss-gedeckt-mit-serviettenfaecher-landhaus-schend-vulkaneifel.jpg", alt: "Hell eingedeckte Festtafel im Landhaus Schend mit weißen Serviettenfächern bei Tageslicht" },  { src: "/fotos/festtafel-am-fenster-mit-gartenblick-landhaus-schend-vulkaneifel.jpg", alt: "Festlich eingedeckte Tafel am Fenster im Landhaus Schend mit Blick in den Garten" },
  { src: "/fotos/eifeler-spezialitaet-gebratene-kloesse-in-rahmsauce-landhaus-schend.jpg", alt: "Eifeler Spezialität im Restaurant Landhaus Schend: gebratene Klöße in Rahmsauce mit Schnittlauch" },
  { src: "/fotos/pelmeni-beimler-landhaus-schend.jpg", alt: "Pelmeni Beimler — hausgemachte Teigtaschen der Familie Beimler im Landhaus Schend" },
  { src: "/fotos/doppelzimmer-bad-mit-walk-in-dusche-und-led-rundspiegel-landhaus-schend-vulkaneifel.jpg", alt: "Modernes Badezimmer im Landhaus Schend mit ebenerdiger Walk-in-Dusche und beleuchtetem LED-Rundspiegel" },
  { src: "/fotos/doppelzimmer-mit-holzbett-landhaus-schend-vulkaneifel.jpg", alt: "Doppelzimmer mit Holzbett" },
  { src: "/fotos/doppelzimmer-comfort-landhaus-schend-vulkaneifel.jpg", alt: "Komfortables Doppelzimmer" },
  { src: "/fotos/komfortzimmer-mit-balkon-landhaus-schend-vulkaneifel.jpg", alt: "Komfortzimmer mit Balkon und Eifel-Blick" },
  { src: "/fotos/familienzimmer-doppelbett-landhaus-schend-vulkaneifel.jpg", alt: "Familienzimmer mit Doppelbett" },
  { src: "/fotos/familienzimmer-mit-nebenraum-landhaus-schend-vulkaneifel.jpg", alt: "Familienzimmer mit separatem Nebenraum" },
  { src: "/fotos/landhaus-schend-schriftzug-fassade-landhaus-schend.jpg", alt: "Fassade mit Schriftzug Landhaus Schend" },
  { src: "/fotos/hotelfassade-mit-garten-landhaus-schend-vulkaneifel.jpg", alt: "Hotelfassade mit Garten" },
  { src: "/fotos/wanderer-am-eifelmaar-landhaus-schend-vulkaneifel.jpg", alt: "Wanderer am Eifelmaar in der Vulkaneifel" },
  { src: "/fotos/radfahrer-am-radweg-landhaus-schend-vulkaneifel.jpg", alt: "Radfahrer auf dem Radweg in der Vulkaneifel" },
  { src: "/fotos/dorfansicht-immerath-landhaus-schend.jpg", alt: "Dorfansicht von Immerath" },
  { src: "/fotos/winterlicher-innenhof-landhaus-schend.jpg", alt: "Winterlicher Innenhof" },
  { src: "/fotos/weihnachtsstimmung-im-schnee-landhaus-schend.jpg", alt: "Weihnachtsstimmung im Schnee" },
  { src: "/fotos/hoteleingang-mit-schneebaum-landhaus-schend-vulkaneifel.jpg", alt: "Hoteleingang mit verschneitem Baum" },
];
---

<Layout
  title="Galerie — Bilder vom Landhaus Schend"
  description="Bildergalerie des Landhaus Schend in Immerath: Haus & Garten, Zimmer, Restaurant und die Vulkaneifel rundum."
  canonicalPath="/galerie"
>
  <section class="container mx-auto px-4 pt-12 md:pt-16 pb-10 text-center max-w-2xl mx-auto">
    <p class="eyebrow">Galerie</p>
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mt-3 text-balance leading-[1.05]">Bilder vom Landhaus Schend</h1>
    <p class="text-muted-foreground mt-5 leading-relaxed text-pretty">
      Haus & Garten, Zimmer, das Landhaus Restaurant und die Vulkaneifel rundum — einige Eindrücke.
    </p>
  </section>

  <section class="container mx-auto px-4 pb-20">
    <div class="gap-3 [column-count:2] lg:[column-count:3]">
      {FOTOS.map((f, i) => (
        <div class="mb-3 break-inside-avoid overflow-hidden rounded-md shadow-card" data-reveal style={`--reveal-delay:${(i % 4) * 0.06}s`}>
          <Pic src={f.src} alt={f.alt} width={dims[f.src]?.[0]} height={dims[f.src]?.[1]} data-lightbox="galerie" class="w-full h-auto block transition-transform duration-700 hover:scale-105" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </section>
</Layout>
