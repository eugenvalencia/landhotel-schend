---
// Galerie — eigene Seite (wie Original-Menü). Alle Bilder self-hosted aus
// /public/fotos. Masonry-Layout via CSS-Columns, beschreibende Alt-Texte (a11y/SEO).
import Layout from "../layouts/Layout.astro";
import Pic from "../components/Pic.astro";
import dimsJson from "../lib/foto-dims.json";
const dims = dimsJson as Record<string, [number, number]>;

const FOTOS = [
  { src: "/fotos/hotelfront-mit-rosen-landhotel-schend-vulkaneifel.jpg", alt: "Hotelfront des Landhotel Schend mit roten Rosen im Sommer" },
  { src: "/fotos/hotelgarten-mit-brunnen-landhotel-schend.jpg", alt: "Hotelgarten mit Brunnen" },
  { src: "/fotos/eingang-mit-torbogen-und-hortensien-landhotel-schend.jpg", alt: "Eingang mit Torbogen und Hortensien" },
  { src: "/fotos/innenhof-mit-balkonen-landhotel-schend-vulkaneifel.jpg", alt: "Innenhof mit blumengeschmückten Balkonen" },
  { src: "/fotos/sonnenterrasse-mit-hortensien-landhotel-schend-vulkaneifel.jpg", alt: "Sonnenterrasse mit Hortensien" },
  { src: "/fotos/gartenseite-mit-terrasse-landhotel-schend.jpg", alt: "Gartenseite mit Terrasse" },
  { src: "/fotos/restaurant-panorama-1-landhotel-schend.jpg", alt: "Landhaus Restaurant — Gastraum" },
  { src: "/fotos/restaurant-panorama-2-landhotel-schend.jpg", alt: "Landhaus Restaurant — gemütliche Atmosphäre" },
  { src: "/fotos/restaurant-panorama-3-landhotel-schend.jpg", alt: "Landhaus Restaurant — Tische und Terrasse" },
  { src: "/fotos/doppelzimmer-mit-holzbett-landhotel-schend-vulkaneifel.jpg", alt: "Doppelzimmer mit Holzbett" },
  { src: "/fotos/doppelzimmer-comfort-landhotel-schend-vulkaneifel.jpg", alt: "Komfortables Doppelzimmer" },
  { src: "/fotos/komfortzimmer-mit-balkon-landhotel-schend-vulkaneifel.jpg", alt: "Komfortzimmer mit Balkon und Eifel-Blick" },
  { src: "/fotos/familienzimmer-doppelbett-landhotel-schend-vulkaneifel.jpg", alt: "Familienzimmer mit Doppelbett" },
  { src: "/fotos/familienzimmer-mit-nebenraum-landhotel-schend-vulkaneifel.jpg", alt: "Familienzimmer mit separatem Nebenraum" },
  { src: "/fotos/landhaus-schend-schriftzug-fassade-landhotel-schend.jpg", alt: "Fassade mit Schriftzug Landhaus Schend" },
  { src: "/fotos/hotelfassade-mit-garten-landhotel-schend-vulkaneifel.jpg", alt: "Hotelfassade mit Garten" },
  { src: "/fotos/wanderer-am-eifelmaar-landhotel-schend-vulkaneifel.jpg", alt: "Wanderer am Eifelmaar in der Vulkaneifel" },
  { src: "/fotos/radfahrer-am-radweg-landhotel-schend-vulkaneifel.jpg", alt: "Radfahrer auf dem Radweg in der Vulkaneifel" },
  { src: "/fotos/dorfansicht-immerath-landhotel-schend.jpg", alt: "Dorfansicht von Immerath" },
  { src: "/fotos/winterlicher-innenhof-landhotel-schend.jpg", alt: "Winterlicher Innenhof" },
  { src: "/fotos/weihnachtsstimmung-im-schnee-landhotel-schend.jpg", alt: "Weihnachtsstimmung im Schnee" },
  { src: "/fotos/hoteleingang-mit-schneebaum-landhotel-schend-vulkaneifel.jpg", alt: "Hoteleingang mit verschneitem Baum" },
];
---

<Layout
  title="Galerie — Bilder vom Landhotel Schend"
  description="Bildergalerie des Landhotel Schend in Immerath: Haus & Garten, Zimmer, Restaurant und die Vulkaneifel rundum."
  canonicalPath="/galerie"
>
  <section class="container mx-auto px-4 pt-12 md:pt-16 pb-10 text-center max-w-2xl mx-auto">
    <p class="eyebrow">Galerie</p>
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mt-3 text-balance leading-[1.05]">Bilder vom Landhotel Schend</h1>
    <p class="text-muted-foreground mt-5 leading-relaxed text-pretty">
      Haus & Garten, Zimmer, das Landhaus Restaurant und die Vulkaneifel rundum — einige Eindrücke.
    </p>
  </section>

  <section class="container mx-auto px-4 pb-20">
    <div class="gap-3 [column-count:2] lg:[column-count:3]">
      {FOTOS.map((f, i) => (
        <div class="mb-3 break-inside-avoid overflow-hidden rounded-md shadow-card" data-reveal style={`--reveal-delay:${(i % 4) * 0.06}s`}>
          <Pic src={f.src} alt={f.alt} width={dims[f.src]?.[0]} height={dims[f.src]?.[1]} data-lightbox="galerie" class="w-full h-auto block transition-transform duration-700 hover:scale-105" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </section>
</Layout>
