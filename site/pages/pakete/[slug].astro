---
// Deutsches Paket-Detail (Root, /pakete/[slug]). Inhalt: components/pages/PaketeDetailPage.astro.
import { PAKETE } from "../../lib/pakete";
import PaketeDetailPage from "../../components/pages/PaketeDetailPage.astro";

export function getStaticPaths() {
  return PAKETE.map((p) => ({ params: { slug: p.slug } }));
}
const { slug } = Astro.params;
---

<PaketeDetailPage lang="de" slug={slug!} />
