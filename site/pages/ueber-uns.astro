---
// Über uns — die 1856-Story (E-E-A-T + GEO). Inhalt 1:1 aus
// src/components/AboutSection.tsx. Timeline statisch sichtbar gerendert
// (kein JS-abhängiges Reveal → Content steht ohne JS im HTML).
import Layout from "../layouts/Layout.astro";
import { ORIGIN } from "../lib/site";

const TIMELINE = [
  { year: "1856", event: "Grundhaus erbaut — Gasthaus & Poststelle" },
  { year: "1954", event: "Eheleute Schneiders übernehmen" },
  { year: "1970", event: "Erste 3 Gästezimmer mit Warmwasser" },
  { year: "1976", event: "Tochter Roswitha steigt ein" },
  { year: "1993", event: "Übernahme durch die Tochter" },
  { year: "1997", event: "Neueröffnung als „Landhaus Schend\"" },
  { year: "1999", event: "Erste 3-Sterne-Klassifizierung" },
  { year: "2019", event: "Übernahme durch Familie Beimler" },
  { year: "Heute", event: "21 Zimmer, ★★★ Superior — geführt von Familie Beimler" },
];

const VALUES = [
  { num: "01", title: "Herzlichkeit", text: "Persönlicher Service mit familiärer Atmosphäre — wir kennen unsere Gäste mit Namen." },
  { num: "02", title: "Qualität", text: "Regionale Eifeler Küche und liebevoll gestaltete Zimmer mit Charakter." },
  { num: "03", title: "Tradition", text: "Über 165 Jahre Gastfreundschaft in Familienhand, generationsübergreifend gepflegt." },
];

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "Über uns — Landhotel Schend",
  url: `${ORIGIN}/ueber-uns`,
  description:
    "Die Geschichte des Landhotel Schend in Immerath: seit 1856 als Gasthaus, heute ★★★ Superior Familienhotel — seit 2019 von Familie Beimler geführt.",
  about: { "@type": "Organization", name: "Landhotel Schend", foundingDate: "1856" },
};
---

<Layout
  title="Über uns — Familienhotel seit 1856 in Immerath"
  description="Die Geschichte des Landhotel Schend: 1856 als Gasthaus & Poststelle erbaut, heute ★★★ Superior Familienhotel in der Vulkaneifel — seit 2019 von Familie Beimler geführt."
  canonicalPath="/ueber-uns"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(aboutSchema)} />

  <!-- History — asymmetrischer Magazine-Spread -->
  <section class="grid lg:grid-cols-12 items-stretch">
    <div class="lg:col-span-6">
      <div class="aspect-[3/4] sm:aspect-[4/5] lg:aspect-auto lg:h-full lg:min-h-[680px] overflow-hidden shadow-elevated">
        <img
          src="/fotos/landhotel-schend-zeichnung-innenhof-historisch.jpg"
          alt="Bleistift-Zeichnung des Landhotel Schend in Immerath mit Innenhof und Eingang"
          class="w-full h-full object-cover object-center contrast-110"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>

    <div class="lg:col-span-6 px-6 md:px-12 lg:px-16 py-16 md:py-24 flex flex-col justify-center" data-reveal>
      <p class="eyebrow">Über uns</p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl mt-4 mb-10 text-balance leading-[1.05]">
        Die Geschichte des Landhotels
      </h1>

      <div class="space-y-5 text-foreground/85 leading-relaxed max-w-prose">
        <p class="drop-cap">
          Anno 1856 wurde das Grundhaus erbaut und diente bereits damals als
          Gasthaus und zeitweise auch als Poststelle für den Ort.
        </p>
        <p>
          <span class="font-display text-primary">1954</span> übernahmen die
          Eheleute Änni und Leo Schneiders die elterliche Dorfgaststätte sowie
          den kleinbäuerlichen Selbstversorgungsbetrieb.
          <span class="font-display text-primary">1970</span> erweiterten sie
          den Betrieb um drei Gästezimmer mit fließendem Warm- und Kaltwasser.
        </p>
        <p>
          Seit <span class="font-display text-primary">1976</span> arbeiteten
          Tochter Roswitha und Ehemann Reinhold im Betrieb mit, den die beiden
          <span class="font-display text-primary">1993</span> übernahmen. Nach
          dem Tod der Eltern entschlossen sie sich für umfangreiche Umbaumaßnahmen:
          Das alte Ökonomiegebäude wurde abgerissen und ein neues Gästehaus mit 22
          Betten errichtet.
        </p>
        <p>
          Zwei Jahre später, <span class="font-display text-primary">1997</span>,
          eröffneten sie das neue Gebäude unter dem Namen „Landhaus Schend". Seit
          <span class="font-display text-primary">1999</span> ist das Landhaus
          Schend mit 3 Sternen der Deutschen Hotelklassifizierung ausgezeichnet.
        </p>
      </div>
    </div>
  </section>

  <!-- Gastgeber — Familie Beimler (seit 2019). PLATZHALTER-Bild: Außenansicht,
       bis das echte Familienfoto vorliegt → dann src + alt tauschen. -->
  <section class="container mx-auto px-4 py-16 md:py-20 border-t border-border/40">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-10 md:gap-14 items-center">
      <div class="aspect-[4/3] overflow-hidden rounded-md shadow-card">
        <img
          src="/fotos/hotelfront-mit-rosen-landhotel-schend-vulkaneifel.jpg"
          alt="Landhotel Schend in Immerath mit Rosen vor der Fassade"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
      <div data-reveal>
        <p class="eyebrow">Ihre Gastgeber</p>
        <h2 class="font-display text-3xl md:text-4xl mt-3 mb-5 leading-tight">Familie Beimler</h2>
        <p class="text-foreground/85 leading-relaxed max-w-prose">
          Seit 2019 führt Familie Beimler das Landhaus Schend und setzt die über
          165-jährige Tradition des Hauses mit Herzblut fort — herzlich, persönlich
          und authentisch eifelerisch.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline — 1856 bis heute. tl-reveal: Linie zeichnet sich, Jahre staffeln,
       Gold-Funke wandert (per IntersectionObserver). Ohne JS voll sichtbar. -->
  <section class="tl-reveal container mx-auto px-4 py-16 md:py-24 border-t border-border/40">
    <div class="text-center mb-12 md:mb-16">
      <p class="eyebrow">165+ Jahre Gastfreundschaft</p>
      <h2 class="font-display text-2xl md:text-3xl lg:text-4xl mt-4 text-balance">
        <span class="font-display-italic font-light">Vom</span> Gasthaus 1856
        <span class="font-display-italic font-light">bis</span> heute
      </h2>
    </div>

    <!-- Desktop — horizontal -->
    <div class="hidden md:block relative max-w-6xl mx-auto">
      <div aria-hidden="true" class="tl-line absolute left-0 right-0 top-1.5 h-px bg-gradient-to-r from-transparent via-secondary/40 to-transparent"></div>
      <span aria-hidden="true" class="tl-glint"></span>
      <ol class="relative grid grid-cols-9 gap-2">
        {TIMELINE.map((item, i) => (
          <li class="tl-item flex flex-col items-center text-center" style={`--i:${i}`}>
            <span aria-hidden="true" class="block h-3 w-3 rounded-full bg-secondary ring-4 ring-background relative z-10"></span>
            <p class="font-display text-secondary text-xl lg:text-2xl mt-4 mb-2">{item.year}</p>
            <p class="text-[10px] lg:text-[11px] text-muted-foreground leading-tight tracking-wide px-1">{item.event}</p>
          </li>
        ))}
      </ol>
    </div>

    <!-- Mobile — vertikal -->
    <div class="md:hidden max-w-md mx-auto">
      <ol class="relative border-l-2 border-secondary/30 ml-3 space-y-6 pl-6">
        {TIMELINE.map((item, i) => (
          <li class="tl-item relative" style={`--i:${i}`}>
            <span aria-hidden="true" class="absolute -left-[1.85rem] top-1 h-3 w-3 rounded-full bg-secondary ring-4 ring-background"></span>
            <p class="font-display text-secondary text-xl">{item.year}</p>
            <p class="text-sm text-muted-foreground leading-relaxed">{item.event}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Philosophie -->
  <section class="container mx-auto px-4 py-20 md:py-28">
    <div class="text-center mb-14 md:mb-20 max-w-3xl mx-auto">
      <p class="eyebrow">Was uns ausmacht</p>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mt-4 mb-8 text-balance">Unsere Philosophie</h2>
      <p class="text-foreground/85 leading-relaxed text-base md:text-lg text-pretty">
        Das Wohl unserer Gäste liegt uns am Herzen. Sie zu begeistern und zu
        verwöhnen ist die Philosophie unseres Hauses, die wir schon seit Bestehen
        pflegen und an unsere Mitarbeiter weitergeben — herzlich, persönlich und
        authentisch eifelerisch.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-px bg-border/50 max-w-5xl mx-auto border border-border/50 rounded-md overflow-hidden shadow-card">
      {VALUES.map((v, i) => (
        <div class="bg-background px-8 py-12 text-center" data-reveal style={`--reveal-delay:${i * 0.1}s`}>
          <p class="font-display text-secondary text-3xl mb-5">{v.num}</p>
          <h3 class="font-display text-xl mb-3">{v.title}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed text-pretty">{v.text}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
