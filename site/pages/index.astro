---

<Layout
  description="Familiengeführtes 3-Sterne-Hotel in Immerath, Vulkaneifel — 21 Zimmer, Eifeler Landküche, Halbpension. Ideal zum Wandern. Provisionsfrei direkt buchen."
  canonicalPath="/"
  ogType="hotel"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(hotelGraph)} />

  <!-- Hero -->
  <section class="relative">
    <img src={HERO_IMG} alt="Landhotel Schend in Immerath, Vulkaneifel" class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    <div class="absolute inset-0 gradient-hero"></div>
    <div class="relative container mx-auto px-4 py-28 md:py-40 max-w-3xl text-[hsl(38_30%_95%)]">
      <span class="inline-block text-[11px] font-semibold tracking-[0.22em] uppercase px-3 py-1 rounded-full border border-white/30 bg-black/20 backdrop-blur-sm">
        3 Sterne Superior
      </span>
      <p class="eyebrow mt-6 !text-[hsl(38_48%_72%)]">Kurzurlaub & Wanderhotel in der Vulkaneifel</p>
      <h1 class="headline-reveal font-display text-5xl md:text-7xl mt-3 text-balance leading-[1.03]">
        Willkommen im Landhotel Schend
      </h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl text-[hsl(38_30%_95%)]/90 text-pretty">
        Ihr ★★★ Superior Hotel in Immerath — Eifelsteig, Maare-Mosel-Radweg und Nürburgring direkt
        vor der Tür. 21 Zimmer mit Balkon, hauseigene Eifeler Landküche, Halbpension auf Wunsch und
        kostenlose Motorradgarage. Ideal für Ihren Kurzurlaub — direkt buchen, provisionsfrei.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/booking" class="inline-flex items-center px-6 py-3 rounded-sm bg-secondary text-secondary-foreground font-semibold tracking-wide hover:bg-secondary/90 transition-colors">
          Jetzt direkt buchen
        </a>
        <a href="tel:+4965731306" class="inline-flex items-center px-6 py-3 rounded-sm border border-white/40 font-semibold tracking-wide hover:bg-white/10 transition-colors">
          +49 6573 306
        </a>
      </div>
    </div>
  </section>

  <!-- USP-Strip -->
  <section class="border-b border-border/50 bg-muted/20">
    <div class="container mx-auto px-4 py-8">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-3 text-sm text-foreground/80">
        {USPS.map((u) => (
          <li class="flex items-center gap-2">
            <svg class="h-3.5 w-3.5 shrink-0 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {u}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Sektionen -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="eyebrow">Entdecken</p>
      <h2 class="font-display text-3xl md:text-4xl mt-3 text-balance">Ihr Aufenthalt im Überblick</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      {SECTIONS.map((s) => (
        <a href={s.href} class="group block p-6 rounded-md border border-border bg-card shadow-card hover:shadow-elevated transition-shadow">
          <div class="flex items-center justify-between gap-3">
            <h3 class="font-display text-2xl">{s.label}</h3>
            {!s.live && <span class="text-[10px] font-semibold tracking-wide uppercase text-muted-foreground border border-border rounded-full px-2 py-0.5">In Vorbereitung</span>}
          </div>
          <p class="text-sm text-muted-foreground mt-2 leading-relaxed">{s.hint}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
