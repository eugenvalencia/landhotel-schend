---

<Layout
  description="Familiengeführtes 3-Sterne-Hotel in Immerath, Vulkaneifel — 21 Zimmer, Eifeler Landküche, Halbpension. Ideal zum Wandern. Provisionsfrei direkt buchen."
  canonicalPath="/"
  ogType="hotel"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(hotelGraph)} />

  <!-- HERO -->
  <section class="relative h-[100vh] min-h-[640px] max-h-[1100px] overflow-hidden">
    <div data-hero-bg aria-hidden="true" class="absolute inset-0 will-change-transform" style="transform: scale(1.22)">
      <img src={HERO_IMG} alt="Vorderansicht des Landhotel Schend mit Rosenbeet in der Vulkaneifel" class="hero-ken-burns absolute inset-0 w-full h-full object-cover" fetchpriority="high" decoding="async" />
    </div>
    <div aria-hidden="true" class="absolute inset-0 bg-black/25"></div>
    <div aria-hidden="true" class="absolute inset-0" style="background: radial-gradient(ellipse 65% 55% at 50% 50%, rgba(0,0,0,0.42) 0%, rgba(0,0,0,0.18) 55%, transparent 100%)"></div>
    <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-80 bg-gradient-to-t from-black/55 via-black/20 to-transparent"></div>
    <div aria-hidden="true" class="hero-grain absolute inset-0 z-[1] pointer-events-none"></div>

    <!-- Wetter (Open-Meteo, client) -->
    <div data-weather hidden class="absolute top-5 right-5 z-10 hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white/90" style="text-shadow:0 1px 3px rgba(0,0,0,0.5)">
      <span data-weather-temp class="tabular-nums text-sm font-medium leading-none"></span>
      <span class="block h-3 w-px bg-white/30" aria-hidden="true"></span>
      <span class="text-[10px] tracking-[0.18em] uppercase leading-none text-white/75">Vulkaneifel</span>
    </div>

    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6">
      <div class="flex items-center gap-4 mb-10 md:mb-14">
        <span class="block h-px w-12 md:w-20 bg-white/65"></span>
        <span class="text-[11px] md:text-xs font-medium tracking-[0.24em] uppercase text-white/90" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">Anno 1856 <a href="/login" aria-label="·" style="color:inherit;text-decoration:none;cursor:text">·</a> Vulkaneifel</span>
        <span class="block h-px w-12 md:w-20 bg-white/65"></span>
      </div>
      <h1 class="headline-reveal font-display text-balance text-white text-[2.5rem] sm:text-5xl md:text-7xl lg:text-[5.5rem] leading-[0.95] mb-7 md:mb-9 max-w-4xl" style="text-shadow:0 2px 14px rgba(0,0,0,0.55)">
        Willkommen im Landhotel Schend
      </h1>
      <p class="font-display-italic text-balance text-white/95 text-lg md:text-2xl max-w-2xl leading-snug mb-9 md:mb-11" style="text-shadow:0 1px 8px rgba(0,0,0,0.55)">
        Ihr ★★★ Superior Hotel in Immerath — Eifelsteig, Maare-Mosel-Radweg und Nürburgring direkt vor der Tür. Eifeler Landküche, Halbpension auf Wunsch, kostenlose Motorradgarage.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 mb-10 md:mb-12 text-white/80" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">
        <span class="text-[11px] md:text-xs tracking-[0.15em] uppercase font-medium"><span class="text-secondary">★</span> Tripadvisor #1</span>
        <span class="text-white/40" aria-hidden="true">·</span>
        <span class="text-[11px] md:text-xs tracking-[0.15em] uppercase font-medium">8,5 / 10 Booking</span>
        <span class="text-white/40" aria-hidden="true">·</span>
        <span class="text-[11px] md:text-xs tracking-[0.15em] uppercase font-medium">165 Jahre Familie</span>
        <span class="text-white/40 hidden sm:inline" aria-hidden="true">·</span>
        <span class="hidden sm:inline text-[11px] md:text-xs tracking-[0.15em] uppercase font-medium">21 Zimmer mit Balkon</span>
      </div>
      <div class="flex flex-col items-center gap-5">
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4">
          <a href="/booking" class="magnetic glow-border group inline-flex items-center justify-center gap-3 px-9 py-4 min-h-[56px] bg-white text-zinc-900 text-xs sm:text-sm font-medium tracking-[0.2em] uppercase rounded-sm hover:bg-secondary hover:text-secondary-foreground transition-colors duration-300 shadow-sm">
            <svg class="h-4 w-4 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"/><path d="m9 16 2 2 4-4"/></svg>
            Jetzt direkt buchen
            <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </a>
          <a href="/restaurant" class="magnetic group inline-flex items-center justify-center gap-3 px-9 py-4 min-h-[56px] border border-white/60 text-white text-xs sm:text-sm font-medium tracking-[0.2em] uppercase rounded-sm hover:bg-white/10 hover:border-white transition-all duration-300" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">
            <svg class="h-4 w-4 sm:h-5 sm:w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            Im Restaurant essen
            <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </a>
        </div>
        <a href="tel:+4965731306" class="text-white/85 text-sm tracking-wide hover:text-white transition-colors" style="text-shadow:0 1px 4px rgba(0,0,0,0.5)">oder anrufen <span class="font-medium ml-1">+49 6573 306</span></a>
      </div>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 text-white/55">
      <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
      <span class="relative block h-10 w-px overflow-hidden bg-white/20"><span aria-hidden="true" class="scroll-cue-travel absolute inset-x-0 top-0 block h-3 bg-white/85"></span></span>
    </div>
  </section>

  <!-- USPs -->
  <section aria-label="Im Haus inbegriffen" class="bg-background border-y border-border/70">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-border/50">
        {USPS.map((u) => (
          <div class="group flex items-center gap-3 px-5 py-7 bg-background hover:bg-muted/40 transition-colors">
            <svg class="h-5 w-5 text-secondary shrink-0 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={uspIcon[u.icon]} />
            <span class="text-[13px] font-medium leading-snug">{u.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ZIMMER -->
  <section id="rooms" class="bg-gradient-to-b from-background via-muted/20 to-background">
    <div class="container mx-auto px-4 py-20 md:py-28">
      <div class="text-center mb-14 md:mb-20" data-reveal>
        <span class="hairline block max-w-[3rem] mx-auto mb-6"></span>
        <p class="eyebrow">Unsere Zimmer</p>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl mt-4 text-balance">Zu Gast im Landhotel Schend</h2>
        <p class="text-muted-foreground mt-5 max-w-prose mx-auto leading-relaxed text-pretty">
          Komfortable Doppelzimmer (auch zur Einzelnutzung) und großzügige Familienzimmer — alle mit Balkon oder Terrasse und Blick in die Vulkaneifel. Frühstücksbuffet inklusive.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-10 max-w-4xl mx-auto">
        {ROOM_TYPES.map((r, idx) => {
          const gallery = galleryForRoomType(r.galleryKey ?? r.type);
          const cardPhoto = gallery[idx % gallery.length] ?? gallery[0];
          return (
            <a href={`/zimmer/${r.slug}`} class="group block" data-reveal style={`--reveal-delay:${idx * 0.08}s`}>
              <div class="spotlight tilt-card card-reveal aspect-[3/4] sm:aspect-[4/5] overflow-hidden mb-5 rounded-md shadow-card group-hover:shadow-elevated transition-shadow duration-500">
                <img src={cardPhoto} alt={r.type} class="w-full h-full object-cover transition-transform duration-[1500ms] ease-out group-hover:scale-[1.04]" loading="lazy" decoding="async" />
                <div class="card-caption">
                  <p class="text-[10px] tracking-[0.2em] uppercase text-white/80 mb-1">Zimmer ansehen</p>
                  <p class="font-display text-white text-lg leading-snug">{r.hint}</p>
                </div>
              </div>
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <h3 class="font-display text-xl md:text-2xl group-hover:text-secondary transition-colors">{r.type}</h3>
                <span class="text-xs font-medium tracking-[0.15em] uppercase text-secondary whitespace-nowrap">{r.priceLabel}</span>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed">{r.hint}</p>
            </a>
          );
        })}
      </div>
      <div class="text-center mt-16">
        <a href="/zimmer" class="inline-flex items-center gap-2 px-9 py-4 rounded-sm border border-primary/40 uppercase tracking-[0.2em] text-xs font-medium hover:border-secondary hover:text-secondary transition-colors">Alle Zimmer & Preise <span>→</span></a>
      </div>
    </div>
  </section>

  <!-- RESTAURANT (voll) -->
  <section id="restaurant" class="bg-gradient-to-b from-muted/40 via-muted/20 to-muted/40">
    <div class="bg-secondary/10 border-b border-border/60">
      <div class="container mx-auto px-4 py-4 md:py-5">
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-center">
          <span class="inline-flex items-center gap-2 text-sm md:text-base font-medium text-foreground">
            <svg class="h-4 w-4 text-secondary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 2v7c0 1.1.9 2 2 2h2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
            Auch ohne Übernachtung — Tagesgäste herzlich willkommen
          </span>
          <a href="tel:+4965731306" class="inline-flex items-center gap-2 text-sm font-medium text-secondary hover:text-foreground transition-colors underline underline-offset-4 decoration-secondary/40">Tisch reservieren: +49 6573 306 →</a>
        </div>
      </div>
    </div>

