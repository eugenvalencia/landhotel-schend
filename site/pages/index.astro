const FAQ_HOME = [
  { q: "Wo liegt das Landhotel Schend genau?", a: "In der Hauptstraße 9, 54552 Immerath, mitten in der Vulkaneifel. Köln ca. 90 Min, Frankfurt ca. 120 Min, Nürburgring ca. 45 Min." },
  { q: "Was kostet eine Übernachtung?", a: "Doppelzimmer ab 57 € pro Person/Nacht inkl. Frühstücksbuffet. Zur Einzelnutzung ab 80 €. Familienzimmer ab 170 €. Halbpension auf Wunsch +23 € pro Person/Tag." },
  { q: "Gibt es einen sicheren Stellplatz für Motorräder?", a: "Ja — kostenlose, videoüberwachte Parkplätze und genügend Motorrad-Stellplätze. Beliebt bei Fahrern rund um den Nürburgring." },
  { q: "Bieten Sie Halbpension an?", a: "Halbpension ist auf Wunsch buchbar (+23 € pro Person/Tag) — täglich frische Eifeler Landküche. Das große Frühstücksbuffet ist immer inklusive." },
  { q: "Warum direkt buchen statt über Booking.com?", a: "Bei Direktbuchung zahlen Sie keine Provision, bekommen den Bestpreis und sind bei Sonderwünschen flexibler — und unterstützen direkt unser Familienunternehmen." },
  { q: "Wann hat das Hotel Saison?", a: "März bis Oktober durchgehend — die schönste Wander- und Radzeit der Eifel. November bis Februar Betriebsferien." },
