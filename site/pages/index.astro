---
// Startseite (Stufe 2, voll) — Hero + USPs + Trust + Zimmer/Pakete/Restaurant/
// Region/Über-uns-Anrisse → echte Themen-Seiten. Volles Hotel-@graph im Head.
// Alle Inhalte real (aus index.html / ReviewsSection / FAQ / pakete / rooms).
import Layout from "../layouts/Layout.astro";
import { ROOM_TYPES } from "../lib/rooms";
import { PAKETE } from "../lib/pakete";

const HERO_IMG = "/fotos/hotelfront-mit-rosen-landhotel-schend-vulkaneifel.jpg";

const USPS = [
  "Kostenlose Parkplätze — videoüberwacht",
  "Genügend Motorrad-Parkplätze — videoüberwacht",
  "Halbpension auf Wunsch",
  "Hauseigenes Restaurant",
  "21 Zimmer mit Balkon/Terrasse",
  "Kostenloses WLAN",
  "Großes Frühstücksbuffet",
  "Booking.com 8.5 · Tripadvisor #1",
];

const PLATFORMS = [
  { name: "Google", score: "4,5 / 5", line: "Sehr gut", reviews: "142 Bewertungen" },
  { name: "Booking.com", score: "8,5 / 10", line: "Sehr gut", reviews: "203 Bewertungen" },
  { name: "Tripadvisor", score: "4,0 / 5", line: "Nr. 1 in Immerath", reviews: "89 Bewertungen" },
  { name: "HRS", score: "8,7 / 10", line: "Empfehlenswert", reviews: "67 Bewertungen" },
];

const REVIEWS = [
  { text: "Wunderschönes Hotel in traumhafter Lage. Das Frühstücksbuffet war legendär — so viel Auswahl haben wir selten erlebt. Zimmer sehr sauber und gemütlich.", author: "Familie Müller, Köln" },
  { text: "Perfekte Lage für Wanderungen in der Vulkaneifel. Das Personal war außerordentlich freundlich und hilfsbereit. Sehr gerne wieder!", author: "Thomas K." },
  { text: "Gemütliches Hotel mit hervorragendem Restaurant. Die Eifeler Küche hat uns begeistert. Genügend Motorrad-Parkplätze sind vorhanden und sicher videoüberwacht.", author: "Bikergruppe aus München" },
];

const REGION = [
  { img: "/pakete/eifel-1.jpg", title: "Eifelsteig", text: "Premium-Wanderweg direkt vorbei am Hotel — Etappe Daun ↔ Manderscheid." },
  { img: "/pakete/eifel-2.jpg", title: "Maare der Vulkaneifel", text: "Immerath-Maar zu Fuß, die Dauner Maare in 15–30 Min — Kraterseen zum Greifen nah." },
  { img: "/pakete/eifel-5.jpg", title: "Maare-Mosel-Radweg & Nürburgring", text: "Radwege ab Hotel, der Nürburgring in ca. 45 Minuten." },
];

const roomTeaser = ROOM_TYPES.slice(0, 3);
const paketTeaser = PAKETE.slice(0, 3);

const hotelGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Hotel",
      "@id": "https://landhaus-schend.de/#hotel",
      name: "Landhotel Schend",
      alternateName: "Landhaus Schend",
      description:
        "Familiengeführtes 3-Sterne-Superior Landhotel in Immerath / Vulkaneifel mit 21 komfortablen Zimmern, hauseigenem Eifeler Restaurant und Halbpension auf Wunsch. Ideal für Kurzurlaub und Wandern in der Vulkaneifel.",
      url: "https://landhaus-schend.de/",
      telephone: "+49-6573-306",
      faxNumber: "+49-6573-99815",
      email: "info@landhaus-schend.de",
      image: [
        "https://landhaus-schend.de/fotos/hotelfront-mit-rosen-landhotel-schend-vulkaneifel.jpg",
        "https://landhaus-schend.de/fotos/hotelfront-mit-blumenbeet-landhotel-schend-vulkaneifel.jpg",
        "https://landhaus-schend.de/fotos/gartenseite-mit-terrasse-landhotel-schend.jpg",
      ],
      logo: "https://landhaus-schend.de/schend-logo-black.svg",
      priceRange: "€€",
      starRating: { "@type": "Rating", ratingValue: "3", additionalType: "Superior" },
      address: {
        "@type": "PostalAddress",
        streetAddress: "Hauptstraße 9",
        addressLocality: "Immerath",
        addressRegion: "Rheinland-Pfalz",
        postalCode: "54552",
        addressCountry: "DE",
      },
      geo: { "@type": "GeoCoordinates", latitude: 50.1303, longitude: 6.9594 },
      hasMap: "https://www.google.com/maps?q=Landhotel+Schend+Immerath",
      checkinTime: "15:00",
      checkoutTime: "11:00",
      numberOfRooms: 21,
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          validFrom: "2026-03-01",
          validThrough: "2026-09-30",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          description: "Saisonbetrieb März bis September. Oktober bis Februar geschlossen.",
        },
      ],
      petsAllowed: "Hunde sind in der Dorfgaststätte erlaubt",
      smokingAllowed: false,
      amenityFeature: [
        { "@type": "LocationFeatureSpecification", name: "Halbpension auf Wunsch", value: true },
        { "@type": "LocationFeatureSpecification", name: "Eifeler Landküche", value: true },
        { "@type": "LocationFeatureSpecification", name: "Kaminzimmer", value: true },
        { "@type": "LocationFeatureSpecification", name: "Sonnenterrasse", value: true },
        { "@type": "LocationFeatureSpecification", name: "Hauseigenes Restaurant", value: true },
        { "@type": "LocationFeatureSpecification", name: "Frühstücksbuffet", value: true },
        { "@type": "LocationFeatureSpecification", name: "Kostenloses WLAN", value: true },
        { "@type": "LocationFeatureSpecification", name: "Kostenloser Parkplatz – videoüberwacht", value: true },
        { "@type": "LocationFeatureSpecification", name: "Mehrere Motorrad-Stellplätze im Hof", value: true },
        { "@type": "LocationFeatureSpecification", name: "Balkon oder Terrasse", value: true },
        { "@type": "LocationFeatureSpecification", name: "Aufzug", value: true },
        { "@type": "LocationFeatureSpecification", name: "Sauna im Haus", value: true },
        { "@type": "LocationFeatureSpecification", name: "Massagen", value: true },
        { "@type": "LocationFeatureSpecification", name: "Familienzimmer", value: true },
        { "@type": "LocationFeatureSpecification", name: "Kinderspielecke", value: true },
      ],
      aggregateRating: { "@type": "AggregateRating", ratingValue: "8.5", bestRating: "10", ratingCount: 250 },
      containsPlace: [
        {
          "@type": "Restaurant",
          "@id": "https://landhaus-schend.de/#restaurant",
          name: "Landhaus Restaurant & Terrasse",
          url: "https://landhaus-schend.de/restaurant",
          telephone: "+49-6573-306",
          servesCuisine: ["Eifeler Landküche", "Deutsch", "Regional"],
          acceptsReservations: "True",
          priceRange: "€€",
        },
      ],
      potentialAction: {
        "@type": "ReserveAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: "https://landhaus-schend.de/booking",
          actionPlatform: ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"],
        },
        result: { "@type": "LodgingReservation", name: "Direktbuchung Zimmer" },
      },
      areaServed: [
        { "@type": "Place", name: "Vulkaneifel" },
        { "@type": "Place", name: "Eifelsteig" },
        { "@type": "Place", name: "Maare-Mosel-Radweg" },
        { "@type": "Place", name: "Nürburgring" },
      ],
    },
    {
      "@type": "Organization",
      "@id": "https://landhaus-schend.de/#organization",
      name: "Landhotel Schend",
      alternateName: "Landhaus Schend",
      url: "https://landhaus-schend.de/",
      logo: "https://landhaus-schend.de/schend-logo-black.svg",
      founder: { "@type": "Person", name: "Familie Schend" },
      foundingDate: "1856",
      contactPoint: {
        "@type": "ContactPoint",
        telephone: "+49-6573-306",
        contactType: "Reservierung",
        areaServed: "DE",
        availableLanguage: ["German", "English", "French"],
      },
      sameAs: [
        "https://www.facebook.com/Landhotel.Schend/",
        "https://www.booking.com/hotel/de/landhaus-schend.html",
        "https://www.tripadvisor.com/Hotel_Review-g2298352-d2330477-Reviews-Landhaus_Schend-Immerath_Rhineland_Palatinate.html",
        "https://www.eifel.info/en/unterkuenfte/landhaus-schend",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://landhaus-schend.de/#website",
      url: "https://landhaus-schend.de/",
      name: "Landhotel Schend",
      publisher: { "@id": "https://landhaus-schend.de/#organization" },
      inLanguage: ["de-DE", "en-US", "fr-FR"],
    },
  ],
};
---

<Layout
  description="Familiengeführtes 3-Sterne-Hotel in Immerath, Vulkaneifel — 21 Zimmer, Eifeler Landküche, Halbpension. Ideal zum Wandern. Provisionsfrei direkt buchen."
  canonicalPath="/"
  ogType="hotel"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(hotelGraph)} />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <img src={HERO_IMG} alt="Landhotel Schend in Immerath, Vulkaneifel" class="hero-ken-burns absolute inset-0 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    <div class="absolute inset-0 gradient-hero"></div>
    <div class="relative container mx-auto px-4 py-28 md:py-40 max-w-3xl text-[hsl(38_30%_95%)]">
      <span class="inline-block text-[11px] font-semibold tracking-[0.22em] uppercase px-3 py-1 rounded-full border border-white/30 bg-black/20 backdrop-blur-sm">3 Sterne Superior</span>
      <p class="eyebrow mt-6 !text-[hsl(38_48%_72%)]">Kurzurlaub & Wanderhotel in der Vulkaneifel</p>
      <h1 class="headline-reveal font-display text-5xl md:text-7xl mt-3 text-balance leading-[1.03]">Willkommen im Landhotel Schend</h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl text-[hsl(38_30%_95%)]/90 text-pretty">
        Ihr ★★★ Superior Hotel in Immerath — Eifelsteig, Maare-Mosel-Radweg und Nürburgring direkt
        vor der Tür. 21 Zimmer mit Balkon, hauseigene Eifeler Landküche, Halbpension auf Wunsch und
        kostenlose Motorradgarage. Ideal für Ihren Kurzurlaub — direkt buchen, provisionsfrei.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/booking" class="inline-flex items-center px-6 py-3 rounded-sm bg-secondary text-secondary-foreground font-semibold tracking-wide hover:bg-secondary/90 transition-colors">Jetzt direkt buchen</a>
        <a href="tel:+4965731306" class="inline-flex items-center px-6 py-3 rounded-sm border border-white/40 font-semibold tracking-wide hover:bg-white/10 transition-colors">+49 6573 306</a>
      </div>
    </div>
  </section>

  <!-- USP-Strip -->
  <section class="border-b border-border/50 bg-muted/20">
    <div class="container mx-auto px-4 py-8">
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-3 text-sm text-foreground/80">
        {USPS.map((u) => (
          <li class="flex items-center gap-2">
            <svg class="h-3.5 w-3.5 shrink-0 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {u}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Trust / Bewertungen -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12" data-reveal>
      <p class="eyebrow">Was Gäste sagen</p>
      <h2 class="font-display text-3xl md:text-4xl mt-3 text-balance">Über 500 Bewertungen, 4,5 ★ im Schnitt</h2>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto mb-12">
      {PLATFORMS.map((p, i) => (
        <div class="text-center p-6 rounded-md border border-border bg-card shadow-card" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
          <p class="text-sm font-semibold text-muted-foreground">{p.name}</p>
          <p class="font-display text-3xl text-secondary mt-2">{p.score}</p>
          <p class="text-xs text-foreground/70 mt-1">{p.line}</p>
          <p class="text-[11px] text-muted-foreground mt-1">{p.reviews}</p>
        </div>
      ))}
    </div>
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {REVIEWS.map((r, i) => (
        <figure class="p-6 rounded-md border border-border bg-card shadow-card flex flex-col" data-reveal style={`--reveal-delay:${i * 0.1}s`}>
          <div class="flex gap-0.5 text-secondary mb-3" aria-hidden="true">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="h-4 w-4 fill-secondary" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <blockquote class="text-sm text-foreground/85 leading-relaxed flex-1 text-pretty">„{r.text}"</blockquote>
          <figcaption class="text-sm font-medium text-muted-foreground mt-4">— {r.author}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- Zimmer-Anriss -->
  <section class="bg-muted/20 border-y border-border/50">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
        <div>
          <p class="eyebrow">Unsere Zimmer</p>
          <h2 class="font-display text-3xl md:text-4xl mt-3 text-balance">21 Zimmer mit Eifel-Blick</h2>
        </div>
        <a href="/zimmer" class="text-sm font-semibold text-secondary hover:text-foreground transition-colors">Alle Zimmer ansehen →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {roomTeaser.map((r, i) => (
          <a href={`/zimmer/${r.slug}`} class="group flex flex-col rounded-md overflow-hidden border border-border bg-card shadow-card hover:shadow-elevated transition-shadow" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
            <div class="aspect-[4/3] overflow-hidden">
              <img src={r.gallery[0]} alt={`${r.type} im Landhotel Schend`} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
            </div>
            <div class="p-5">
              <h3 class="font-display text-xl group-hover:text-secondary transition-colors">{r.type}</h3>
              <p class="text-sm text-secondary font-medium mt-1">{r.priceLabel}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pakete-Anriss -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
      <div>
        <p class="eyebrow">Angebote & Pauschalen</p>
        <h2 class="font-display text-3xl md:text-4xl mt-3 text-balance">Pauschalen für Ihre Auszeit</h2>
      </div>
      <a href="/pakete" class="text-sm font-semibold text-secondary hover:text-foreground transition-colors">Alle Pauschalen →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {paketTeaser.map((p, i) => (
        <a href={`/pakete/${p.slug}`} class="group flex flex-col rounded-md overflow-hidden border border-border bg-card shadow-card hover:shadow-elevated transition-shadow" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
          <div class="aspect-[4/3] overflow-hidden">
            <img src={p.cover} alt={p.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
          </div>
          <div class="p-5">
            <h3 class="font-display text-xl group-hover:text-secondary transition-colors text-balance">{p.title}</h3>
            {p.price && <p class="text-sm text-secondary font-medium mt-1">{p.price}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Restaurant-Band -->
  <section class="relative">
    <img src="/fotos/restaurant-panorama-1-landhotel-schend.jpg" alt="Landhaus Restaurant im Landhotel Schend" class="absolute inset-0 h-full w-full object-cover" loading="lazy" decoding="async" />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="relative container mx-auto px-4 py-24 md:py-32 text-center text-white" data-reveal>
      <p class="eyebrow !text-[hsl(38_48%_72%)]">Kulinarik</p>
      <h2 class="font-display text-4xl md:text-5xl mt-3 text-balance">Landhaus Restaurant & Terrasse</h2>
      <p class="mt-5 max-w-2xl mx-auto text-white/90 leading-relaxed text-pretty">
        Eifeler Landküche, frische regionale Zutaten und frisch gezapftes Bitburger — auch für
        Tagesgäste ohne Übernachtung. Festtafel für Feiern bis 80 Personen.
      </p>
      <a href="/restaurant" class="inline-flex items-center mt-8 px-6 py-3 rounded-sm bg-white text-zinc-900 font-semibold tracking-wide hover:bg-secondary hover:text-secondary-foreground transition-colors">Zum Restaurant</a>
    </div>
  </section>

  <!-- Über-uns-Anriss -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto" data-reveal>
      <div class="aspect-[4/3] overflow-hidden rounded-md shadow-elevated order-2 lg:order-1">
        <img src="/fotos/landhotel-schend-zeichnung-innenhof-historisch.jpg" alt="Historische Zeichnung des Landhotel Schend" class="w-full h-full object-cover contrast-110" loading="lazy" decoding="async" />
      </div>
      <div class="order-1 lg:order-2">
        <p class="eyebrow">Seit 1856</p>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl mt-3 mb-6 text-balance leading-[1.05]">Familienhotel in der 5. Generation</h2>
        <p class="text-foreground/85 leading-relaxed text-pretty mb-6">
          Was 1856 als Gasthaus und Poststelle begann, führen wir heute als ★★★ Superior Hotel —
          über 165 Jahre Eifeler Gastfreundschaft in Familienhand. Herzlich, persönlich und
          authentisch eifelerisch.
        </p>
        <a href="/ueber-uns" class="text-sm font-semibold text-secondary hover:text-foreground transition-colors">Unsere Geschichte →</a>
      </div>
    </div>
  </section>

  <!-- Region -->
  <section class="bg-muted/20 border-y border-border/50">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <div class="text-center max-w-2xl mx-auto mb-12" data-reveal>
        <p class="eyebrow">Urlaubsregion</p>
        <h2 class="font-display text-3xl md:text-4xl mt-3 text-balance">Die Vulkaneifel vor der Tür</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {REGION.map((r, i) => (
          <div class="rounded-md overflow-hidden border border-border bg-card shadow-card" data-reveal style={`--reveal-delay:${i * 0.08}s`}>
            <div class="aspect-[16/10] overflow-hidden">
              <img src={r.img} alt={r.title} class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
            <div class="p-5">
              <h3 class="font-display text-xl">{r.title}</h3>
              <p class="text-sm text-muted-foreground mt-2 leading-relaxed text-pretty">{r.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ-Anriss + Final-CTA -->
  <section class="container mx-auto px-4 py-16 md:py-24 text-center max-w-2xl" data-reveal>
    <p class="eyebrow">Noch Fragen?</p>
    <h2 class="font-display text-3xl md:text-4xl mt-3 text-balance">Alles Wichtige auf einen Blick</h2>
    <p class="text-muted-foreground mt-5 leading-relaxed text-pretty">
      Lage, Zimmer, Halbpension, Restaurant, Wandern und Direktbuchung — die häufigsten Fragen
      beantworten wir kurz und ehrlich.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href="/faq" class="inline-flex items-center px-6 py-3 rounded-sm border border-border font-semibold tracking-wide hover:bg-muted transition-colors">Zu den FAQ</a>
      <a href="/booking" class="inline-flex items-center px-6 py-3 rounded-sm bg-secondary text-secondary-foreground font-semibold tracking-wide hover:bg-secondary/90 transition-colors">Jetzt direkt buchen</a>
    </div>
  </section>
</Layout>
