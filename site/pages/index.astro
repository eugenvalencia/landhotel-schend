---
// Startseite (INTERIM Stufe 1) — navigierbar mit Header/Footer, realem Hero-Copy
// (aus src/i18n.ts), USP-Strip und dem vollständigen Hotel-@graph (kanonische
// Entität, reale Daten aus index.html → dauerhaft korrekt, sofort GEO-stark).
// Die voll ausgebaute visuelle Startseite (Galerie, Sektionen, Reviews) kommt
// in Stufe 2.
import Layout from "../layouts/Layout.astro";

const HERO_IMG = "/fotos/hotelfront-mit-rosen-landhotel-schend-vulkaneifel.jpg";

const USPS = [
  "Kostenlose Parkplätze — videoüberwacht",
  "Genügend Motorrad-Parkplätze — videoüberwacht",
  "Halbpension auf Wunsch",
  "Hauseigenes Restaurant",
  "21 Zimmer mit Balkon/Terrasse",
  "Kostenloses WLAN",
  "Großes Frühstücksbuffet",
  "Booking.com 8.5 · Tripadvisor #1",
];

const SECTIONS = [
  { label: "Über uns", href: "/ueber-uns", hint: "Familienhotel seit 1856 — die Geschichte", live: true },
  { label: "FAQ", href: "/faq", hint: "Antworten zu Lage, Zimmern, Restaurant & Buchung", live: true },
  { label: "Zimmer", href: "/zimmer", hint: "21 Zimmer & Suiten mit Balkon", live: false },
  { label: "Pakete", href: "/pakete", hint: "Angebote & Pauschalen für die Eifel", live: false },
  { label: "Gastronomie", href: "/restaurant", hint: "Eifeler Landküche & Terrasse", live: false },
];

// Volles Hotel-@graph — 1:1 aus index.html der Vite-App (reale Stammdaten).
