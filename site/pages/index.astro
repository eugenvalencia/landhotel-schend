// Echte Bewertungs-Plattformen — verlinkt auf die echten Schend-Profile.
// Scores aus den öffentlichen Profilen (Stand-Snapshot, vor Go-Live mit Karin
// final verifizieren — Bewertungen ändern sich). Keine erfundenen Zahlen,
// keine erfundenen Bewertungs-Anzahlen, keine erfundenen Gäste-Zitate.
const PLATFORMS = [
  { name: "Booking.com", logo: "/reviews/booking.svg", score: "8,7 / 10", line: "Sehr gut · Nr. 1 in Immerath", href: "https://www.booking.com/hotel/de/landhaus-schend.html" },
  { name: "Tripadvisor", logo: "/reviews/tripadvisor.svg", score: "4,0 / 5", line: "Nr. 1 in Immerath", href: "https://www.tripadvisor.com/Hotel_Review-g2298352-d2330477-Reviews-Landhaus_Schend-Immerath_Rhineland_Palatinate.html" },
  { name: "HRS", mark: "HRS", brand: "#1d4ed8", score: "9,0 / 10", line: "100 % Weiterempfehlung", href: "https://www.hrs.com/en/hotel/schend-landhaus/a-542374/" },
  { name: "Google", logo: "/reviews/google.svg", score: "", line: "Rezensionen auf Google lesen", href: "https://www.google.com/maps/search/?api=1&query=Landhaus+Schend+Immerath" },
