---
// Startseite — originalgetreu nach der alten Seite (src/pages/Index.tsx):
// Hero → USPs → Zimmer → Restaurant (voll) → Pakete → Urlaubsregion → Über uns
// → Bewertungen → FAQ → Standort/Karte. Inhalte real, Effekte als Progressive
// Enhancement, mobil-first. FAQPage-/Hotel-Detailschema liegen auf den Unterseiten.
import Layout from "../layouts/Layout.astro";
import Pic from "../components/Pic.astro";
import LocationSection from "../components/LocationSection.astro";
import { ROOM_TYPES } from "../lib/rooms";
import { PAKETE } from "../lib/pakete";
import { SCHEND_RESTAURANT, galleryForRoomType } from "../lib/photos";

// Hero-Hintergrund: Video (Runway, Sommerbrise) mit Standbild als Poster/Fallback.
// INTERIM: das MP4 trägt noch das Runway-Free-Plan-Wasserzeichen ("runway", unten
// rechts) — nach dem Paid-Upgrade gegen die saubere, höher aufgelöste Version
// tauschen (gleicher Pfad, nur Datei ersetzen). TODO: Upgrade-Swap.
const HERO_VIDEO = "/hero/schend-hero.mp4";
const HERO_POSTER = "/hero/schend-hero-poster.jpg";

