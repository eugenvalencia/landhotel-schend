        { "@type": "LocationFeatureSpecification", name: "Kinderspielecke", value: true },
      ],
      aggregateRating: { "@type": "AggregateRating", ratingValue: "8.5", bestRating: "10", ratingCount: 250 },
      containsPlace: [
        {
          "@type": "Restaurant",
