  <!-- Abschnitts-Navigation (Punkte rechts) — zeigt die aktuelle Position auf der Seite -->
  <nav id="section-dots" aria-label="Abschnitts-Navigation" data-visible="false" inert class="flex fixed right-2 lg:right-5 top-1/2 -translate-y-1/2 z-40 flex-col gap-1.5 lg:gap-3 opacity-0 pointer-events-none transition-opacity duration-500">
    {[["top","Start"],["rooms","Zimmer"],["restaurant","Restaurant"],["pakete","Pakete"],["reviews","Bewertungen"],["location","Anfahrt"]].map(([id,label]) => (
      <a href={`#${id}`} data-dot={id} aria-label={label} class="dot-link group relative grid place-items-center w-8 h-8 lg:w-5 lg:h-5">
        <span class="dot block rounded-full w-2 h-2 lg:w-1.5 lg:h-1.5 bg-secondary/70 drop-shadow-[0_1px_2px_rgba(0,0,0,0.5)] transition-all duration-300 ease-out group-hover:bg-secondary group-hover:scale-110"></span>
        <span class="absolute right-full mr-3 px-2.5 py-1 rounded-sm bg-foreground/95 text-background text-[10px] uppercase tracking-[0.18em] font-medium whitespace-nowrap opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0 transition-all duration-300 pointer-events-none">{label}</span>
      </a>
    ))}
  </nav>
  <style>
    #section-dots[data-visible="true"] { opacity: 1; pointer-events: auto; }
    #section-dots .dot-link[data-active="true"] .dot {
      width: 0.75rem; height: 0.75rem;
      background: hsl(var(--secondary));
      box-shadow: 0 0 8px hsl(var(--secondary) / 0.4);
    }
  </style>
  <script>
    // Abschnitts-Punkte — aktive Section über Anchor-Punkt (40% Viewport),
    // gespeist von der Lenis-Scroll-Brücke (window.__onScroll).
    (function () {
      const nav = document.getElementById("section-dots");
      if (!nav) return;
      const ids = ["top", "rooms", "restaurant", "pakete", "reviews", "location"];
      const links = Array.from(nav.querySelectorAll<HTMLElement>("[data-dot]"));
      const update = (y: number) => {
        const anchorY = y + window.innerHeight * 0.4;
        let bestId = "top";
        let bestStart = -Infinity;
        for (const id of ids) {
          const el = document.getElementById(id);
          if (!el) continue;
          const rect = el.getBoundingClientRect();
          const start = rect.top + y;
          if (anchorY >= start && anchorY < start + rect.height && start > bestStart) {
            bestStart = start;
            bestId = id;
          }
        }
        links.forEach((a) =>
          a.setAttribute("data-active", a.getAttribute("data-dot") === bestId ? "true" : "false"),
        );
        const visible = y > window.innerHeight * 0.6;
        nav.setAttribute("data-visible", visible ? "true" : "false");
        // opacity:0 allein bleibt tabbar — inert nimmt die versteckten Punkte
        // aus Tab-Reihenfolge + Screenreader (WCAG 2.4.3 / 2.4.7).
        (nav as HTMLElement & { inert: boolean }).inert = !visible;
      };
      if ((window as any).__onScroll) (window as any).__onScroll(update);
      else {
        update(window.scrollY);
        window.addEventListener("scroll", () => update(window.scrollY), { passive: true });
      }
      window.addEventListener("resize", () => update((window as any).__lenis?.scroll ?? window.scrollY));
    })();
  </script>

  <script>
    // Hero-Video nur abspielen, wenn der Nutzer Bewegung erlaubt — sonst bleibt
    // das Poster-Standbild stehen (Barrierefreiheit, prefers-reduced-motion).
    // Es MUSS laufen, solange es sichtbar ist (Desktop + Handy). Browser pausieren
    // <video> gern bei Tab-Wechsel/Energiesparen/Scroll — darum aktiv selbstheilend:
    //   - spielt, sobald es im Viewport + Tab aktiv ist
    //   - pausiert nur, wenn es aus dem Bild gescrollt ist (spart Strom/Akku)
    //   - wirft sich nach Browser-Auto-Pause sofort wieder an
    // Motion-Off = OS-prefers-reduced-motion ODER In-App-Komfort-Schalter
    // (html.a11y-reduced-motion, gesetzt vom A11yPanel) — wie Layout.astro.
    const heroVideo = document.querySelector<HTMLVideoElement>("[data-hero-video]");
    const motionOff = window.matchMedia("(prefers-reduced-motion: reduce)").matches
      || document.documentElement.classList.contains("a11y-reduced-motion");
    // Mobil (< 768px) das 2,4-MB-Hero-Video NICHT laden/abspielen — Poster bleibt LCP.
    const noHeroVideo = motionOff || !window.matchMedia("(min-width: 768px)").matches;
    if (heroVideo && noHeroVideo) {
      heroVideo.pause();
    } else if (heroVideo) {
      let inView = true;
      const tryPlay = () => {
        if (inView && !document.hidden && heroVideo.paused) heroVideo.play().catch(() => {});
      };

      // Mobil holt bei preload="metadata" ohne .play() KEINE Mediendaten nach
      // (canplay feuert dann nie). Darum sofort versuchen + an mehreren
      // Lade-Events erneut anwerfen, statt nur auf canplay zu warten.
      tryPlay();
      heroVideo.addEventListener("loadedmetadata", tryPlay, { once: true });
      heroVideo.addEventListener("loadeddata", tryPlay, { once: true });
      heroVideo.addEventListener("canplay", tryPlay, { once: true });

      // Im Bild -> spielen, raus -> pausieren.
      if ("IntersectionObserver" in window) {
        new IntersectionObserver((entries) => {
          inView = entries[0].isIntersecting;
          if (inView) tryPlay();
          else heroVideo.pause();
        }, { threshold: 0.1 }).observe(heroVideo);
      }

      // Zurück zum Tab -> weiterspielen.
      document.addEventListener("visibilitychange", () => { if (!document.hidden) tryPlay(); });

      // Browser hat selbst pausiert (Energiesparen/Handy) -> wieder anwerfen,
      // solange es sichtbar sein soll. Kurzer Tick gegen Pause-Event-Schleife.
      heroVideo.addEventListener("pause", () => {
        if (inView && !document.hidden && !heroVideo.ended) setTimeout(tryPlay, 150);
      });
    }

    // Hero-Parallax (Bildebene scrollt langsamer, Scale bleibt erhalten).
    const bg = document.querySelector<HTMLElement>("[data-hero-bg]");
    if (bg && !motionOff) {
      let raf = 0;
      const applyParallax = (sy: number) => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const h = bg.offsetHeight || 1;
          const y = Math.min(sy * 0.3, h * 0.06);
          bg.style.transform = `translate3d(0, ${y}px, 0) scale(1.22)`;
        });
      };
      // Zentrale Scroll-Brücke (Lenis-kompatibel) statt window-"scroll".
      if ((window as any).__onScroll) {
        (window as any).__onScroll(applyParallax);
      } else {
        applyParallax(window.scrollY);
        window.addEventListener("scroll", () => applyParallax(window.scrollY), { passive: true });
      }
    }

  </script>
</Layout>
