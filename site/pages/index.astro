  <LocationSection />

  <script>
    // Hero-Parallax (Bildebene scrollt langsamer, Scale bleibt erhalten).
    const bg = document.querySelector<HTMLElement>("[data-hero-bg]");
    if (bg && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      let raf = 0;
      const onScroll = () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const h = bg.offsetHeight || 1;
          const y = Math.min(window.scrollY * 0.3, h * 0.06);
          bg.style.transform = `translate3d(0, ${y}px, 0) scale(1.22)`;
        });
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    }

    // Live-Wetter (Open-Meteo) — im Datenschutz als Auftragsdienst gelistet.
    const wx = document.querySelector<HTMLElement>("[data-weather]");
    const wxt = document.querySelector<HTMLElement>("[data-weather-temp]");
    if (wx && wxt) {
      fetch("https://api.open-meteo.com/v1/forecast?latitude=50.1303&longitude=6.9594&current=temperature_2m")
        .then((r) => r.json())
        .then((d) => {
          const t = d?.current?.temperature_2m;
          if (typeof t === "number") { wxt.textContent = `${Math.round(t)}°`; wx.hidden = false; wx.classList.remove("hidden"); }
        })
        .catch(() => {});
    }
  </script>
