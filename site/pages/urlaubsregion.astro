---
// Urlaubsregion — eigene Seite (wie Original-Menü). Inhalte real aus den
// FAQ-Angaben (Eifelsteig, Maare, Radwege, Nürburgring, Distanzen).
import Layout from "../layouts/Layout.astro";

const HIGHLIGHTS = [
  {
    img: "/fotos/wanderer-am-eifelmaar-landhotel-schend-vulkaneifel.jpg",
    title: "Wandern auf dem Eifelsteig",
    text: "Der Premium-Wanderweg Eifelsteig (300 km von Aachen nach Trier) führt nahe am Hotel vorbei — wir liegen auf der Etappenstrecke Daun ↔ Manderscheid. Dazu der Maar-Pfad und unzählige Rundwege ab Immerath. Wanderkarten und persönliche Tourenempfehlungen stellen wir kostenlos.",
  },
  {
    img: "/pakete/eifel-1.jpg",
    title: "Die Maare der Vulkaneifel",
    text: "Das Immerath-Maar erreichen Sie zu Fuß. In 15–30 Autominuten liegen die drei Dauner Maare (Gemündener, Weinfelder, Schalkenmehrener) sowie Meerfelder Maar, Pulvermaar und Holzmaar. Die Rundwanderung über die Dauner Maare mit dem Dronketurm ist eine der schönsten Tagestouren der Eifel.",
  },
  {
    img: "/fotos/radfahrer-am-radweg-landhotel-schend-vulkaneifel.jpg",
    title: "Radfahren & Nürburgring",
    text: "Maare-Mosel-Radweg und Kylltal-Radweg starten direkt am Hotel — für Genussradler und Mountainbiker. Der Nürburgring ist in ca. 45 Minuten erreichbar; die kurvenreichen Eifelstraßen machen uns zu einem beliebten Ziel für Motorradfahrer.",
  },
  {
    img: "/pakete/eifel-4.jpg",
    title: "Sternenhimmel & Natur",
    text: "Die Vulkaneifel ist ideal zum Sternegucken — der zertifizierte Sternenpark des Nationalpark Eifel liegt rund 60–80 Minuten entfernt. Auch über Immerath gibt es bei klarem Himmel hervorragende Sicht auf die Milchstraße. Gerne geben wir Tipps für die besten Beobachtungsplätze.",
  },
];

const AUSFLUEGE = [
  "Maarmuseum Manderscheid",
  "Vulkanhaus Strohn",
  "Wildpark & Kurstadt Daun",
  "Schulmuseum Immerath",
  "Mosel & Weinorte",
  "Tagestouren nach Luxemburg & Belgien",
];

const DISTANZEN = [
  { ort: "Köln", zeit: "ca. 90 Min" },
  { ort: "Frankfurt am Main", zeit: "ca. 120 Min" },
  { ort: "Nürburgring", zeit: "ca. 45 Min" },
  { ort: "Luxemburg", zeit: "ca. 90 Min" },
];
---

<Layout
  title="Vulkaneifel — Wandern, Maare & Eifelsteig"
  description="Die Vulkaneifel rund um das Landhotel Schend in Immerath: Eifelsteig, Maare, Maare-Mosel-Radweg, Nürburgring und Sternenpark — alles direkt vor der Tür."
  canonicalPath="/urlaubsregion"
>
  <!-- Hero -->
  <section class="relative">
    <img src="/pakete/eifel-2.jpg" alt="Landschaft der Vulkaneifel" class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" decoding="async" />
    <div class="absolute inset-0 gradient-hero"></div>
    <div class="relative container mx-auto px-4 py-24 md:py-32 max-w-3xl text-[hsl(38_30%_95%)]" style="text-shadow:0 1px 8px rgba(0,0,0,0.45)">
      <p class="eyebrow !text-[hsl(38_48%_72%)]">Urlaubsregion</p>
      <h1 class="font-display text-4xl md:text-6xl mt-3 text-balance leading-[1.05]">Die Vulkaneifel vor der Tür</h1>
      <p class="mt-6 text-lg leading-relaxed max-w-2xl text-[hsl(38_30%_95%)]/90 text-pretty">
        Kraterseen, Premium-Wanderwege und Radrouten beginnen direkt am Hotel. Das Landhotel Schend
        liegt mitten in der Vulkaneifel — eingebettet in die Kratermulde eines erloschenen Vulkans,
        fernab vom Großstadttrubel.
      </p>
    </div>
  </section>

  <!-- Highlights -->
  <section class="container mx-auto px-4 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {HIGHLIGHTS.map((h, i) => (
        <article class="spotlight rounded-md overflow-hidden border border-border bg-card shadow-card" data-reveal style={`--reveal-delay:${(i % 2) * 0.1}s`}>
          <div class="aspect-[16/10] overflow-hidden">
            <img src={h.img} alt={h.title} class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <div class="p-6">
            <h2 class="font-display text-2xl">{h.title}</h2>
            <p class="text-sm text-muted-foreground mt-3 leading-relaxed text-pretty">{h.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Ausflüge + Distanzen -->
  <section class="bg-muted/20 border-y border-border/50">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div>
          <h2 class="font-display text-2xl md:text-3xl mb-6">Ausflugsziele in der Nähe</h2>
          <ul class="space-y-3">
            {AUSFLUEGE.map((a) => (
              <li class="flex items-start gap-3 text-foreground/85">
                <svg class="h-5 w-5 shrink-0 mt-0.5 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {a}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="font-display text-2xl md:text-3xl mb-6">So nah sind Sie dran</h2>
          <ul class="space-y-3">
            {DISTANZEN.map((d) => (
              <li class="flex items-center justify-between border-b border-border/60 pb-3">
                <span class="font-medium">{d.ort}</span>
                <span class="text-muted-foreground text-sm">{d.zeit}</span>
              </li>
            ))}
          </ul>
          <p class="text-sm text-muted-foreground mt-4">Adresse: Hauptstraße 9, 54552 Immerath · Vulkaneifel</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container mx-auto px-4 py-16 md:py-20 text-center max-w-2xl">
    <h2 class="font-display text-3xl md:text-4xl text-balance">Ihr Ausgangspunkt für die Eifel</h2>
    <p class="text-muted-foreground mt-4 leading-relaxed text-pretty">
      21 Komfortzimmer, hauseigene Eifeler Landküche und persönliche Tourenempfehlungen —
      ideal für Ihren Aktiv- oder Erholungsurlaub in der Vulkaneifel.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href="/zimmer" class="inline-flex items-center px-6 py-3 rounded-sm border border-border font-semibold tracking-wide hover:bg-muted transition-colors">Zimmer ansehen</a>
      <a href="/booking" class="inline-flex items-center px-6 py-3 rounded-sm bg-secondary text-secondary-foreground font-semibold tracking-wide hover:bg-secondary/90 transition-colors">Jetzt direkt buchen</a>
    </div>
  </section>
</Layout>
