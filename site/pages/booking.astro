---
// Anfrage / Buchung — Felder 1:1 von der echten Schend-Seite (/kontakt).
// Kein Live-Kalender (Verfügbarkeit prüft das Hotel manuell) — eine Anfrage.
// Versand interim per mailto an info@landhaus-schend.de (zero Backend/Kosten);
// echter Server-Versand (z. B. via Mail-Service) kommt beim Go-Live.
import Layout from "../layouts/Layout.astro";
import { PAKETE } from "../lib/pakete";
---

<Layout
  title="Anfrage & Buchung"
  description="Stellen Sie Ihre unverbindliche Zimmer-Anfrage an das Landhotel Schend in Immerath — provisionsfrei direkt beim Hotel."
  canonicalPath="/booking"
  noindex={true}
>
  <section class="container mx-auto px-4 pt-12 md:pt-16 pb-24 max-w-3xl">
    <div class="text-center mb-10 md:mb-12">
      <p class="eyebrow">Direkt & provisionsfrei</p>
      <h1 class="font-display text-4xl md:text-5xl mt-3 text-balance leading-[1.05]">Zimmer anfragen</h1>
      <p class="text-muted-foreground mt-4 leading-relaxed text-pretty">
        Senden Sie uns unverbindlich Ihre Wunsch-Daten — wir melden uns persönlich mit einem Angebot.
        Lieber telefonisch? <a href="tel:+4965731306" class="text-secondary hover:underline">+49 6573 306</a>
      </p>
    </div>

    <form id="anfrage-form" class="space-y-8" novalidate>
      <div class="grid sm:grid-cols-2 gap-x-6 gap-y-5">
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Vorname & Nachname *</span>
          <input name="name" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">E-Mail *</span>
          <input name="email" type="email" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Straße mit Hausnummer *</span>
          <input name="strasse" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Telefon *</span>
          <input name="telefon" type="tel" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Wohnort *</span>
          <input name="wohnort" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Anzahl Personen *</span>
          <select name="personen" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors">
            {[1, 2, 3, 4, 5, 6].map((n) => <option value={n}>{n} {n === 1 ? "Person" : "Personen"}</option>)}
          </select>
        </label>
      </div>

      <div class="grid sm:grid-cols-2 gap-x-6 gap-y-5">
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Anreisedatum *</span>
          <input name="anreise" type="date" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block">
          <span class="block text-sm font-medium mb-1.5">Abreisedatum *</span>
          <input name="abreise" type="date" required class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors" />
        </label>
        <label class="block sm:col-span-2">
          <span class="block text-sm font-medium mb-1.5">Paket</span>
          <select name="paket" class="w-full bg-transparent border-b border-input py-2 focus:border-secondary outline-none transition-colors">
            <option value="Zimmer ohne Paket buchen">Zimmer ohne Paket buchen</option>
            {PAKETE.filter((p) => p.slug !== "zimmer-ohne-paket").map((p) => <option value={p.title}>{p.title}</option>)}
          </select>
        </label>
      </div>

      <fieldset class="space-y-3">
        <legend class="text-sm font-medium mb-1">Zimmerwunsch</legend>
        {[
          { id: "dz_einzel", label: "Doppelzimmer Einzelnutzung" },
          { id: "doppelzimmer", label: "Doppelzimmer" },
          { id: "familienzimmer", label: "Familienzimmer" },
        ].map((r) => (
          <div class="flex items-center justify-between gap-4 py-1">
            <label class="flex items-center gap-3">
              <input type="checkbox" name={`zimmer_${r.id}`} value={r.label} class="h-5 w-5 accent-[hsl(var(--secondary))]" />
              <span>{r.label}</span>
            </label>
            <select name={`anzahl_${r.id}`} aria-label={`Anzahl ${r.label}`} class="bg-transparent border-b border-input py-1.5 px-1 focus:border-secondary outline-none text-sm">
              {[1, 2, 3, 4].map((n) => <option value={n}>{n} Zimmer</option>)}
            </select>
          </div>
        ))}
      </fieldset>

      <label class="block">
        <span class="block text-sm font-medium mb-1.5">Nachricht</span>
        <textarea name="nachricht" rows="4" class="w-full bg-transparent border border-input rounded-md p-3 focus:border-secondary outline-none transition-colors"></textarea>
      </label>

      <div class="flex flex-wrap gap-x-8 gap-y-3">
        <label class="flex items-center gap-3"><input type="checkbox" name="kinderbett" value="ja" class="h-5 w-5 accent-[hsl(var(--secondary))]" /> Zusätzliches Kinderbett</label>
        <label class="flex items-center gap-3"><input type="checkbox" name="hund" value="ja" class="h-5 w-5 accent-[hsl(var(--secondary))]" /> Reise mit Hund</label>
      </div>

      <label class="flex items-start gap-3">
        <input type="checkbox" name="datenschutz" required class="h-5 w-5 mt-0.5 accent-[hsl(var(--secondary))]" />
        <span class="text-sm">Ich habe die <a href="/datenschutz" class="text-secondary underline hover:no-underline">Datenschutzhinweise</a> gelesen und akzeptiert. *</span>
      </label>

      <p data-form-error class="hidden text-sm text-destructive" role="alert"></p>

      <div class="flex flex-col sm:flex-row items-center gap-4 pt-2">
        <button type="submit" class="magnetic glow-border inline-flex items-center justify-center px-9 py-4 min-h-[56px] rounded-sm bg-secondary text-secondary-foreground font-semibold tracking-[0.16em] uppercase text-sm hover:bg-secondary/90 transition-colors">
          Anfrage senden
        </button>
        <span class="text-xs text-muted-foreground">Unverbindlich · provisionsfrei · keine Online-Zahlung</span>
      </div>
    </form>
  </section>

  <script>
    const form = document.getElementById("anfrage-form") as HTMLFormElement | null;
    const errEl = document.querySelector<HTMLElement>("[data-form-error]");
    const showErr = (msg: string) => { if (errEl) { errEl.textContent = msg; errEl.classList.remove("hidden"); } };

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const get = (k: string) => String(fd.get(k) || "").trim();

      // Pflichtfelder
      const required: [string, string][] = [
        ["name", "Name"], ["email", "E-Mail"], ["strasse", "Straße"], ["telefon", "Telefon"],
        ["wohnort", "Wohnort"], ["anreise", "Anreisedatum"], ["abreise", "Abreisedatum"],
      ];
      for (const [k, label] of required) {
        if (!get(k)) return showErr(`Bitte ausfüllen: ${label}.`);
      }
      if (!fd.get("datenschutz")) return showErr("Bitte stimmen Sie den Datenschutzhinweisen zu.");

      // Zimmerwunsch sammeln
      const zimmer: string[] = [];
      for (const id of ["dz_einzel", "doppelzimmer", "familienzimmer"]) {
        if (fd.get(`zimmer_${id}`)) zimmer.push(`${fd.get(`zimmer_${id}`)} (${get(`anzahl_${id}`)} Zimmer)`);
      }

      const lines = [
        `Name: ${get("name")}`,
        `E-Mail: ${get("email")}`,
        `Telefon: ${get("telefon")}`,
        `Adresse: ${get("strasse")}, ${get("wohnort")}`,
        `Anreise: ${get("anreise")}  Abreise: ${get("abreise")}`,
        `Personen: ${get("personen")}`,
        `Paket: ${get("paket")}`,
        `Zimmerwunsch: ${zimmer.length ? zimmer.join(", ") : "—"}`,
        `Kinderbett: ${fd.get("kinderbett") ? "ja" : "nein"}`,
        `Hund: ${fd.get("hund") ? "ja" : "nein"}`,
        ``,
        `Nachricht:`,
        get("nachricht") || "—",
      ];
      const subject = `Zimmer-Anfrage: ${get("name")} (${get("anreise")}–${get("abreise")})`;
      window.location.href = `mailto:info@landhaus-schend.de?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(lines.join("\n"))}`;
    });
  </script>
</Layout>
